{% extends 'base.html.twig' %}

{% block title %}Mi Perfil — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <main class="max-w-5xl mx-auto px-4 py-6">

        {# ── Header ──────────────────────────────────────────────────────────── #}
        <div class="flex items-center gap-6 mb-8">
            <div class="flex-shrink-0">
                {% if app.user.profilePictureFilename %}
                    <img src="{{ '/uploads/profile_pictures/' ~ app.user.profilePictureFilename }}"
                         alt="Foto de perfil"
                         class="w-20 h-20 rounded-full object-cover ring-2 ring-indigo-200">
                {% else %}
                    <div class="w-20 h-20 rounded-full bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center text-2xl font-bold text-indigo-600 dark:text-indigo-300 ring-2 ring-indigo-200">
                        {{ app.user.firstName|slice(0,1)|upper }}{{ app.user.lastName|slice(0,1)|upper }}
                    </div>
                {% endif %}
                {% if is_granted('ROLE_ATLETA') %}
                <a href="{{ path('profile_picture_show') }}" class="mt-1 block text-center text-xs text-indigo-600 dark:text-indigo-400 hover:underline">
                    Cambiar foto
                </a>
                {% endif %}
            </div>
            <div class="flex-1 min-w-0">
                <h1 class="text-2xl font-bold text-gray-900 dark:text-white truncate">{{ app.user.firstName }} {{ app.user.lastName }}</h1>
                <div class="mt-1 flex flex-wrap items-center gap-2">
                    <span class="text-xs font-medium bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 px-2 py-0.5 rounded-full">Atleta</span>
                    {% if fitbitToken and fitbitToken.isValid %}
                        <span class="text-xs font-medium bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 px-2 py-0.5 rounded-full">Fitbit conectado</span>
                    {% else %}
                        <span class="text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 px-2 py-0.5 rounded-full">Sin dispositivo</span>
                    {% endif %}
                </div>
                <div class="mt-1 text-sm text-gray-500 dark:text-gray-400 flex flex-wrap gap-4">
                    {% if app.user.age is defined and app.user.age is not null %}
                        <span>{{ app.user.age }} años</span>
                    {% endif %}
                    {% if app.user.heightCm is defined and app.user.heightCm is not null %}
                        <span>{{ app.user.heightCm }} cm</span>
                    {% endif %}
                    {% if latestMeasurement is not null and latestMeasurement.weightKg is not null %}
                        <span>{{ latestMeasurement.weightKg }} kg</span>
                    {% endif %}
                </div>
                {% if fitbitToken and fitbitToken.isValid %}
                <div class="mt-1 text-xs text-gray-400 dark:text-gray-500">
                    Fitbit · conectado {{ fitbitToken.connectedAt|date('d/m/Y') }}
                </div>
                {% endif %}
            </div>
            {% if is_granted('ROLE_ATLETA') %}
            <div class="flex-shrink-0">
                <a href="{{ path('profile_measurement_new') }}"
                   class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition">
                    + Nueva Medición
                </a>
            </div>
            {% endif %}
        </div>

        {# ── Tab nav + panels ─────────────────────────────────────────────────── #}
        <div data-controller="profile-tabs">

            <nav class="flex border-b border-gray-200 dark:border-gray-700 mb-6">
                <button data-action="click->profile-tabs#show"
                        data-profile-tabs-tab-param="resumen"
                        data-profile-tabs-target="tab"
                        class="px-4 py-2 text-sm font-medium border-b-2 border-indigo-500 text-indigo-600 dark:text-indigo-400 -mb-px">
                    Resumen
                </button>
                <button data-action="click->profile-tabs#show"
                        data-profile-tabs-tab-param="mediciones"
                        data-profile-tabs-target="tab"
                        class="px-4 py-2 text-sm font-medium text-gray-500 hover:text-gray-700 dark:text-gray-400 -mb-px">
                    Mediciones
                </button>
                <button data-action="click->profile-tabs#show"
                        data-profile-tabs-tab-param="historial"
                        data-profile-tabs-target="tab"
                        class="px-4 py-2 text-sm font-medium text-gray-500 hover:text-gray-700 dark:text-gray-400 -mb-px">
                    Historial
                </button>
                <button data-action="click->profile-tabs#show"
                        data-profile-tabs-tab-param="ajustes"
                        data-profile-tabs-target="tab"
                        class="px-4 py-2 text-sm font-medium text-gray-500 hover:text-gray-700 dark:text-gray-400 -mb-px">
                    Ajustes
                </button>
            </nav>

            {# ═══════════════════════════════════════════════════════════════════ #}
            {# TAB: RESUMEN                                                        #}
            {# ═══════════════════════════════════════════════════════════════════ #}
            <div data-profile-tabs-target="panel" data-tab="resumen">

                {# Verdict badge helper macro #}
                {% set verdictClass = {
                    'STABLE':            'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
                    'GOOD':              'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
                    'CAUTION':           'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200',
                    'ALERT':             'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200',
                    'POOR':              'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200',
                    'INSUFFICIENT_DATA': 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300'
                } %}

                {# Row 1 — Daily score cards #}
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">

                    {# Sleep score #}
                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Sueño</p>
                        {% set sleepScore = scores['sleep_scoring'] is defined ? scores['sleep_scoring'] : null %}
                        {% if sleepScore is not null and sleepScore.score is defined and sleepScore.score >= 0 %}
                            <p class="text-3xl font-bold text-gray-900 dark:text-white">{{ sleepScore.score|number_format(0) }}</p>
                            {% set sv = sleepScore.verdict ?? 'INSUFFICIENT_DATA' %}
                            <span class="mt-1 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold {{ verdictClass[sv] ?? verdictClass['INSUFFICIENT_DATA'] }}">
                                {{ sv|replace({'_': ' '}) }}
                            </span>
                        {% else %}
                            <p class="text-3xl font-bold text-gray-400 dark:text-gray-500">—</p>
                            <span class="mt-1 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300">Sin datos</span>
                        {% endif %}
                    </div>

                    {# Recovery score #}
                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Recuperación</p>
                        {% set recovScore = scores['recovery_index'] is defined ? scores['recovery_index'] : null %}
                        {% if recovScore is not null and recovScore.score is defined and recovScore.score >= 0 %}
                            <p class="text-3xl font-bold text-gray-900 dark:text-white">{{ recovScore.score|number_format(0) }}</p>
                            {% set rv = recovScore.verdict ?? 'INSUFFICIENT_DATA' %}
                            <span class="mt-1 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold {{ verdictClass[rv] ?? verdictClass['INSUFFICIENT_DATA'] }}">
                                {{ rv|replace({'_': ' '}) }}
                            </span>
                        {% else %}
                            <p class="text-3xl font-bold text-gray-400 dark:text-gray-500">—</p>
                            <span class="mt-1 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300">Sin datos</span>
                        {% endif %}
                    </div>

                    {# Weekly load #}
                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Carga semanal</p>
                        <p class="text-3xl font-bold text-gray-900 dark:text-white">{{ weeklyTonnage|number_format(0, ',', '.') }} <span class="text-base font-normal text-gray-500 dark:text-gray-400">kg</span></p>
                        {% set fatigueVerdict = scores['fatigue_detection'] is defined ? scores['fatigue_detection'] : null %}
                        {% if fatigueVerdict is not null and fatigueVerdict.verdict is defined %}
                            {% set fv = fatigueVerdict.verdict %}
                            <span class="mt-1 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold {{ verdictClass[fv] ?? verdictClass['INSUFFICIENT_DATA'] }}">
                                {{ fv|replace({'_': ' '}) }}
                            </span>
                        {% else %}
                            <span class="mt-1 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300">Sin datos</span>
                        {% endif %}
                    </div>

                </div>

                {# Row 2 — Health metrics 2×2 #}
                <div class="grid grid-cols-2 gap-4 mb-6">

                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">FC en reposo</p>
                        {% if restingHR is not null %}
                            <p class="text-2xl font-bold text-gray-900 dark:text-white">{{ restingHR }} <span class="text-sm font-normal text-gray-500 dark:text-gray-400">bpm</span></p>
                        {% else %}
                            <p class="text-2xl font-bold text-gray-400 dark:text-gray-500">—</p>
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400">Sin datos de Fitbit</span>
                        {% endif %}
                    </div>

                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">HRV (RMSSD)</p>
                        {% if wellness is not null and wellness.rmssd is not null %}
                            <p class="text-2xl font-bold text-gray-900 dark:text-white">{{ wellness.rmssd|number_format(1) }} <span class="text-sm font-normal text-gray-500 dark:text-gray-400">ms</span></p>
                        {% else %}
                            <p class="text-2xl font-bold text-gray-400 dark:text-gray-500">—</p>
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400">Requiere Fitbit Premium</span>
                        {% endif %}
                    </div>

                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">SpO₂ nocturno</p>
                        {% if wellness is not null and wellness.spo2Avg is not null %}
                            <p class="text-2xl font-bold text-gray-900 dark:text-white">{{ wellness.spo2Avg|number_format(1) }} <span class="text-sm font-normal text-gray-500 dark:text-gray-400">%</span></p>
                        {% else %}
                            <p class="text-2xl font-bold text-gray-400 dark:text-gray-500">—</p>
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400">Requiere Fitbit Premium</span>
                        {% endif %}
                    </div>

                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Frec. respiratoria</p>
                        {% if wellness is not null and wellness.breathingRate is not null %}
                            <p class="text-2xl font-bold text-gray-900 dark:text-white">{{ wellness.breathingRate|number_format(1) }} <span class="text-sm font-normal text-gray-500 dark:text-gray-400">rpm</span></p>
                        {% else %}
                            <p class="text-2xl font-bold text-gray-400 dark:text-gray-500">—</p>
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400">Requiere Fitbit Premium</span>
                        {% endif %}
                    </div>

                </div>

                {# Row 3 — RHR Sparkline #}
                {% if sparklineJson is defined and sparklineJson != '[]' %}
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 mb-6"
                     data-controller="hr-sparkline"
                     data-hr-sparkline-chart-data-value="{{ sparklineJson|e('html_attr') }}">
                    <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">FC en reposo — 14 días</h3>
                    <div class="h-24">
                        <canvas data-hr-sparkline-target="canvas"></canvas>
                    </div>
                </div>
                {% endif %}

                {# Row 4 — Body composition mini-cards #}
                {% if latestMeasurement is not null %}
                <div class="overflow-x-auto mb-6">
                    <div class="flex gap-3 min-w-max sm:grid sm:grid-cols-4 sm:min-w-0">

                        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 min-w-[120px]">
                            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Peso</p>
                            <p class="text-xl font-bold text-gray-900 dark:text-white">
                                {% if latestMeasurement.weightKg is not null %}{{ latestMeasurement.weightKg }} <span class="text-xs font-normal text-gray-400">kg</span>{% else %}—{% endif %}
                            </p>
                        </div>

                        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 min-w-[120px]">
                            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Cintura</p>
                            <p class="text-xl font-bold text-gray-900 dark:text-white">
                                {% if latestMeasurement.waistCm is not null %}{{ latestMeasurement.waistCm }} <span class="text-xs font-normal text-gray-400">cm</span>{% else %}—{% endif %}
                            </p>
                        </div>

                        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 min-w-[120px]">
                            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Pecho</p>
                            <p class="text-xl font-bold text-gray-900 dark:text-white">
                                {% if latestMeasurement.chestCm is not null %}{{ latestMeasurement.chestCm }} <span class="text-xs font-normal text-gray-400">cm</span>{% else %}—{% endif %}
                            </p>
                        </div>

                        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 min-w-[120px]">
                            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Brazos</p>
                            <p class="text-xl font-bold text-gray-900 dark:text-white">
                                {% if latestMeasurement.armsCm is not null %}{{ latestMeasurement.armsCm }} <span class="text-xs font-normal text-gray-400">cm</span>{% else %}—{% endif %}
                            </p>
                        </div>

                    </div>
                    {% if latestMeasurement.measurementDate is defined %}
                    <p class="mt-2 text-xs text-gray-400 dark:text-gray-500">Última medición: {{ latestMeasurement.measurementDate|date('d/m/Y') }}</p>
                    {% endif %}
                </div>
                {% endif %}

                {# Row 5 — Training volume 2×2 #}
                <div class="grid grid-cols-2 gap-4 mb-6">

                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Sesiones esta semana</p>
                        <p class="text-3xl font-bold text-gray-900 dark:text-white">{{ weekWorkouts }}</p>
                    </div>

                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Tonelaje semanal</p>
                        <p class="text-3xl font-bold text-gray-900 dark:text-white">{{ weeklyTonnage|number_format(0, ',', '.') }} <span class="text-base font-normal text-gray-500 dark:text-gray-400">kg</span></p>
                    </div>

                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Fatiga</p>
                        {% set fatigueV = scores['fatigue_detection'] is defined ? scores['fatigue_detection'] : null %}
                        {% if fatigueV is not null and fatigueV.verdict is defined %}
                            {% set fv2 = fatigueV.verdict %}
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold {{ verdictClass[fv2] ?? verdictClass['INSUFFICIENT_DATA'] }}">
                                {{ fv2|replace({'_': ' '}) }}
                            </span>
                        {% else %}
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400">Sin datos</span>
                        {% endif %}
                    </div>

                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Volumen</p>
                        {% set volVerdict = scores['training_volume'] is defined ? scores['training_volume'] : null %}
                        {% if volVerdict is not null and volVerdict.verdict is defined %}
                            {% set vv = volVerdict.verdict %}
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold {{ verdictClass[vv] ?? verdictClass['INSUFFICIENT_DATA'] }}">
                                {{ vv|replace({'_': ' '}) }}
                            </span>
                        {% else %}
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400">Sin datos</span>
                        {% endif %}
                    </div>

                </div>

                {# Row 6 — Daily goals #}
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 mb-6">
                    <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-4">Objetivos del día</h3>

                    {# Steps goal #}
                    {% set stepsVal = todaySteps ?? 0 %}
                    {% set stepsGoalVal = stepsGoal ?? 10000 %}
                    {% set stepsPct = stepsGoalVal > 0 ? min((stepsVal / stepsGoalVal * 100), 100)|round : 0 %}
                    <div class="mb-4">
                        <div class="flex justify-between text-xs text-gray-500 dark:text-gray-400 mb-1">
                            <span>Pasos</span>
                            <span>{{ stepsVal|number_format(0, ',', '.') }} / {{ stepsGoalVal|number_format(0, ',', '.') }}</span>
                        </div>
                        <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                            <div class="h-2 rounded-full transition-all {% if stepsPct >= 80 %}bg-green-500{% elseif stepsPct >= 50 %}bg-amber-500{% else %}bg-red-500{% endif %}"
                                 style="width: {{ stepsPct }}%"></div>
                        </div>
                    </div>

                    {# Sleep goal #}
                    {% set sleepVal = sleepMinutes ?? 0 %}
                    {% set sleepGoalVal = sleepGoal ?? 480 %}
                    {% set sleepPct = sleepGoalVal > 0 ? min((sleepVal / sleepGoalVal * 100), 100)|round : 0 %}
                    {% set sleepH = (sleepVal // 60) %}
                    {% set sleepM = (sleepVal % 60) %}
                    <div>
                        <div class="flex justify-between text-xs text-gray-500 dark:text-gray-400 mb-1">
                            <span>Sueño</span>
                            <span>{% if sleepVal > 0 %}{{ sleepH }}h {{ sleepM }}m{% else %}0h{% endif %} / 8h</span>
                        </div>
                        <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                            <div class="h-2 rounded-full transition-all {% if sleepPct >= 80 %}bg-green-500{% elseif sleepPct >= 50 %}bg-amber-500{% else %}bg-red-500{% endif %}"
                                 style="width: {{ sleepPct }}%"></div>
                        </div>
                    </div>
                </div>

                {# Activity quick-links for Fitbit sub-pages #}
                {% if fitbitToken and fitbitToken.isValid %}
                <div class="flex flex-wrap gap-3 mb-6">
                    <a href="{{ path('profile_sleep') }}"
                       class="inline-flex items-center gap-2 rounded-md bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        Sueño →
                    </a>
                    <a href="{{ path('profile_cardio') }}"
                       class="inline-flex items-center gap-2 rounded-md bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        Cardio →
                    </a>
                    <a href="{{ path('daily_steps_index') }}"
                       class="inline-flex items-center gap-2 rounded-md bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                        Pasos →
                    </a>
                </div>
                {% endif %}

            </div>

            {# ═══════════════════════════════════════════════════════════════════ #}
            {# TAB: MEDICIONES                                                     #}
            {# ═══════════════════════════════════════════════════════════════════ #}
            <div data-profile-tabs-target="panel" data-tab="mediciones" class="hidden">

                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100">Historial de Mediciones</h2>
                    {% if is_granted('ROLE_ATLETA') %}
                    <a href="{{ path('profile_measurement_new') }}"
                       class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition">
                        + Nueva medición
                    </a>
                    {% endif %}
                </div>

                <div class="mb-6 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5"
                     data-controller="measurement-chart"
                     data-measurement-chart-url-value="{{ path('profile_measurement_list') }}"
                     data-measurement-chart-fields-value="{{ ['weight_kg', 'chest_cm', 'waist_cm', 'hips_cm', 'arms_cm']|json_encode }}">
                    <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-4">Evolución de medidas</h3>
                    <div class="relative h-64">
                        <canvas data-measurement-chart-target="canvas"></canvas>
                    </div>
                </div>

                <div
                    data-controller="measurement-pagination"
                    data-measurement-pagination-url-value="{{ path('profile_measurement_list') }}"
                    data-measurement-pagination-edit-url-value="{{ path('profile_measurement_edit', {id: '__ID__'}) }}"
                    data-measurement-pagination-delete-url-value="{{ path('profile_measurement_delete', {id: '__ID__'}) }}"
                >
                    <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                            <thead class="bg-gray-50 dark:bg-gray-900/50">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Fecha</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Peso (kg)</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Pecho (cm)</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Cintura (cm)</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Caderas (cm)</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Brazos (cm)</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Acciones</th>
                                </tr>
                            </thead>
                            <tbody
                                class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-800"
                                data-measurement-pagination-target="tableBody"
                            ></tbody>
                        </table>
                    </div>

                    <div class="hidden rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-6 py-12 text-center shadow-sm mt-2"
                         data-measurement-pagination-target="emptyState">
                        <p class="text-sm text-gray-500 dark:text-gray-400">No tienes mediciones registradas todavía.</p>
                        <a href="{{ path('profile_measurement_new') }}"
                           class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline">
                            + Añadir primera medición
                        </a>
                    </div>

                    <nav class="mt-4 flex items-center justify-between" data-measurement-pagination-target="pagination">
                        <div class="text-sm text-gray-500 dark:text-gray-400">
                            <span data-measurement-pagination-target="pageInfo">Cargando...</span>
                        </div>
                        <div class="flex gap-2">
                            <button type="button"
                                    data-measurement-pagination-target="prevButton"
                                    data-action="click->measurement-pagination#prevPage"
                                    class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 disabled:cursor-not-allowed disabled:opacity-50">
                                Anterior
                            </button>
                            <button type="button"
                                    data-measurement-pagination-target="nextButton"
                                    data-action="click->measurement-pagination#nextPage"
                                    class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 disabled:cursor-not-allowed disabled:opacity-50">
                                Siguiente
                            </button>
                        </div>
                    </nav>
                </div>

            </div>

            {# ═══════════════════════════════════════════════════════════════════ #}
            {# TAB: HISTORIAL                                                      #}
            {# ═══════════════════════════════════════════════════════════════════ #}
            <div data-profile-tabs-target="panel" data-tab="historial" class="hidden">

                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 mb-6"
                     data-controller="activity-calendar"
                     data-activity-calendar-url-value="{{ path('profile_activity_calendar') }}">
                    <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Actividad — últimas 13 semanas</h3>
                    <div class="overflow-x-auto">
                        <div data-activity-calendar-target="container"></div>
                    </div>
                </div>

                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 mb-6">
                    <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Records personales</h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        <a href="{{ path('profile_personal_records') }}" class="text-indigo-600 dark:text-indigo-400 hover:underline">Ver records →</a>
                    </p>
                </div>

                {% if is_granted('ROLE_ATLETA') %}
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300">Historial reciente de entrenamientos</h3>
                        <a href="{{ path('history_index') }}" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">Ver todo →</a>
                    </div>
                    {% if recentHistory is defined and recentHistory|length > 0 %}
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
                            <thead>
                                <tr>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Fecha</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Sesión</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Estado</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Duración</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                                {% for log in recentHistory %}
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                    <td class="px-3 py-2 text-gray-700 dark:text-gray-300">{{ log.startTime|date('d/m/Y') }}</td>
                                    <td class="px-3 py-2 text-gray-700 dark:text-gray-300">{{ log.workoutSession.name }}</td>
                                    <td class="px-3 py-2">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                                            {% if log.status.value == 'completed' %}bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200
                                            {% elseif log.status.value == 'in_progress' %}bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200
                                            {% else %}bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300{% endif %}">
                                            {{ log.status.value|replace({'_': ' '})|capitalize }}
                                        </span>
                                    </td>
                                    <td class="px-3 py-2 text-gray-700 dark:text-gray-300">
                                        {% if log.endTime %}
                                            {{ ((log.endTime.timestamp - log.startTime.timestamp) / 60)|round }} min
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <p class="text-sm text-gray-500 dark:text-gray-400">Aún no has completado ningún entrenamiento.</p>
                    {% endif %}
                </div>
                {% endif %}

            </div>

            {# ═══════════════════════════════════════════════════════════════════ #}
            {# TAB: AJUSTES                                                        #}
            {# ═══════════════════════════════════════════════════════════════════ #}
            <div data-profile-tabs-target="panel" data-tab="ajustes" class="hidden">

                {# Fitbit integration #}
                {% if is_granted('ROLE_ATLETA') %}
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 mb-6">
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-4">Integración Fitbit</h3>

                    {% set fitbitTokenSettings = app.user.fitbitToken %}
                    {% if fitbitTokenSettings is null %}
                        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
                            Conecta tu cuenta de Fitbit para sincronizar automáticamente pasos, sueño y frecuencia cardíaca.
                        </p>
                        <a href="{{ path('fitbit_connect') }}"
                           class="inline-flex items-center rounded-md bg-[#00B0B9] px-4 py-2 text-sm font-semibold text-white hover:bg-[#009aa3]">
                            Conectar Fitbit
                        </a>
                    {% elseif not fitbitTokenSettings.isValid %}
                        <div class="flex items-center gap-2 mb-3">
                            <span class="inline-flex items-center rounded-full bg-yellow-50 dark:bg-yellow-900/30 px-2.5 py-0.5 text-xs font-medium text-yellow-800 dark:text-yellow-300">
                                Token expirado
                            </span>
                        </div>
                        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
                            La conexión con Fitbit ha expirado. Vuelve a conectar tu cuenta.
                        </p>
                        <a href="{{ path('fitbit_connect') }}"
                           class="inline-flex items-center rounded-md bg-[#00B0B9] px-4 py-2 text-sm font-semibold text-white hover:bg-[#009aa3]">
                            Reconectar Fitbit
                        </a>
                    {% else %}
                        <div class="flex items-center gap-2 mb-4">
                            <span class="inline-flex items-center rounded-full bg-green-50 dark:bg-green-900/30 px-2.5 py-0.5 text-xs font-medium text-green-700 dark:text-green-300">
                                Conectado
                            </span>
                            <span class="text-xs text-gray-500 dark:text-gray-400">
                                desde {{ fitbitTokenSettings.connectedAt|date('d/m/Y') }}
                            </span>
                        </div>
                        <div
                            data-controller="fitbit-sync"
                            data-fitbit-sync-url-value="{{ path('fitbit_sync') }}"
                            data-fitbit-sync-csrf-value="{{ csrf_token('fitbit_sync') }}"
                            class="mb-4"
                        >
                            <button
                                type="button"
                                data-action="click->fitbit-sync#sync"
                                data-fitbit-sync-target="button"
                                class="inline-flex items-center gap-2 rounded-md bg-[#00B0B9] px-4 py-2 text-sm font-semibold text-white hover:bg-[#009aa3] disabled:opacity-60 disabled:cursor-not-allowed transition"
                            >
                                <span data-fitbit-sync-target="label">Sincronizar ahora</span>
                                <span data-fitbit-sync-target="spinner" class="hidden">
                                    <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
                                    </svg>
                                </span>
                            </button>
                            <p data-fitbit-sync-target="message" class="mt-2 text-sm hidden"></p>
                        </div>
                        <form method="post" action="{{ path('fitbit_disconnect') }}"
                              onsubmit="return confirm('¿Desconectar Fitbit? Los datos ya sincronizados se conservarán.')">
                            <input type="hidden" name="_token" value="{{ csrf_token('fitbit_disconnect') }}">
                            <button type="submit" class="text-sm font-medium text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300">
                                Desconectar
                            </button>
                        </form>

                        {# Premium reconnect notice if wellness data is empty #}
                        {% if wellness is null or (wellness.rmssd is null and wellness.spo2Avg is null and wellness.breathingRate is null) %}
                        <div class="mt-4 rounded-lg bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-800 p-3 text-sm text-indigo-800 dark:text-indigo-300">
                            Reconecta tu Fitbit para activar métricas Premium (HRV, SpO₂, temperatura).
                            <a href="{{ path('fitbit_connect') }}" class="font-semibold underline ml-1">Reconectar →</a>
                        </div>
                        {% endif %}
                    {% endif %}
                </div>
                {% endif %}

                {# Demographics info #}
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 mb-6">
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-4">Datos personales</h3>
                    <dl class="space-y-3 text-sm">
                        <div class="flex justify-between">
                            <dt class="text-gray-500 dark:text-gray-400">Nombre</dt>
                            <dd class="font-medium text-gray-900 dark:text-gray-100">{{ app.user.firstName }} {{ app.user.lastName }}</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-gray-500 dark:text-gray-400">Email</dt>
                            <dd class="font-medium text-gray-900 dark:text-gray-100">{{ app.user.email }}</dd>
                        </div>
                        {% if app.user.birthDate is defined and app.user.birthDate is not null %}
                        <div class="flex justify-between">
                            <dt class="text-gray-500 dark:text-gray-400">Fecha de nacimiento</dt>
                            <dd class="font-medium text-gray-900 dark:text-gray-100">{{ app.user.birthDate|date('d/m/Y') }}</dd>
                        </div>
                        {% endif %}
                        {% if app.user.heightCm is defined and app.user.heightCm is not null %}
                        <div class="flex justify-between">
                            <dt class="text-gray-500 dark:text-gray-400">Altura</dt>
                            <dd class="font-medium text-gray-900 dark:text-gray-100">{{ app.user.heightCm }} cm</dd>
                        </div>
                        {% endif %}
                    </dl>
                    <div class="mt-4">
                        <a href="{{ path('profile_picture_show') }}" class="text-sm text-indigo-600 dark:text-indigo-400 hover:underline">Cambiar foto de perfil →</a>
                    </div>
                </div>

                {# Active mesocycle info #}
                {% if activeMesocycle is defined and activeMesocycle is not null %}
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4">
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Mesociclo activo</h3>
                    <div class="inline-flex items-center gap-2 rounded-md bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 px-4 py-2 text-sm text-green-800 dark:text-green-300">
                        <span class="font-semibold">{{ activeMesocycle.mesocycle.title }}</span>
                        <span class="text-xs">(desde {{ activeMesocycle.startDate|date('d/m/Y') }})</span>
                    </div>
                    {% if activeMesocycle.mesocycle.dailyStepsTarget is not null %}
                    <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
                        Objetivo de pasos: {{ activeMesocycle.mesocycle.dailyStepsTarget|number_format(0, ',', '.') }} pasos/día
                    </p>
                    {% endif %}
                </div>
                {% endif %}

            </div>

        </div>{# end profile-tabs controller #}

    </main>
</div>
{% endblock %}
