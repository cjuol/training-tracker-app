{% extends 'base.html.twig' %}

{% block title %}Mi Perfil — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        {# ── Profile header ──────────────────────────────────────────────────── #}
        <div class="flex items-start gap-6 mb-8">

            {# Avatar #}
            <div class="flex-shrink-0">
                {% if app.user.profilePictureFilename %}
                    <img
                        src="{{ '/uploads/profile_pictures/' ~ app.user.profilePictureFilename }}"
                        alt="Foto de perfil"
                        class="w-24 h-24 rounded-full object-cover ring-2 ring-indigo-200"
                    >
                {% else %}
                    <div class="w-24 h-24 rounded-full bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center text-2xl font-bold text-indigo-600 dark:text-indigo-300 ring-2 ring-indigo-200">
                        {{ app.user.firstName|slice(0,1) }}{{ app.user.lastName|slice(0,1) }}
                    </div>
                {% endif %}
                {% if is_granted('ROLE_ATLETA') %}
                <a href="{{ path('profile_picture_show') }}" class="mt-2 block text-center text-xs text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300">
                    Cambiar foto
                </a>
                {% endif %}
            </div>

            {# Name + email + active mesocycle #}
            <div class="flex-1">
                <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Mi Perfil</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{{ app.user.fullName }} — {{ app.user.email }}</p>

                {# Active mesocycle card #}
                <div class="mt-4">
                    {% if activeMesocycle %}
                        <div class="inline-flex items-center gap-2 rounded-md bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 px-4 py-2 text-sm text-green-800 dark:text-green-300">
                            <span class="font-semibold">Mesociclo activo:</span>
                            <a href="{{ path('athlete_mesocycle_show', {id: activeMesocycle.id}) }}"
                               class="underline hover:text-green-600 dark:text-green-400">
                                {{ activeMesocycle.mesocycle.title }}
                            </a>
                            <span class="text-green-600 dark:text-green-400 text-xs">(desde {{ activeMesocycle.startDate|date('d/m/Y') }})</span>
                        </div>
                        {% if activeMesocycle.mesocycle.dailyStepsTarget is not null %}
                            <span class="text-xs text-green-700 dark:text-green-400 mt-1 block">Objetivo de pasos: {{ activeMesocycle.mesocycle.dailyStepsTarget|number_format(0, ',', '.') }} pasos/día</span>
                        {% endif %}
                    {% else %}
                        <p class="text-sm text-gray-400 dark:text-gray-500 italic">Sin mesociclo activo asignado.</p>
                    {% endif %}
                </div>
            </div>

            {# CTA: new measurement #}
            {% if is_granted('ROLE_ATLETA') %}
            <div class="flex-shrink-0">
                <a href="{{ path('profile_measurement_new') }}"
                   class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition">
                    + Nueva Medición
                </a>
            </div>
            {% endif %}
        </div>

        {# ── Fitbit health circles (steps + sleep + cardio) ──────────────────── #}
        {% set circumference = 282.74 %}
        {# Steps ratio #}
        {% if todaySteps is not null and stepsTarget is not null and stepsTarget > 0 %}
            {% set stepsRatio = min(todaySteps / stepsTarget, 1.0) %}
            {% set stepsDashoffset = circumference * (1 - stepsRatio) %}
        {% else %}
            {% set stepsDashoffset = circumference %}
        {% endif %}
        {# Sleep ratio #}
        {% set sleepMinutesVal = sleepMinutes is defined ? sleepMinutes : 0 %}
        {% set sleepTargetVal  = sleepTarget  is defined ? sleepTarget  : 480 %}
        {% set sleepRatio = sleepTargetVal > 0 ? min(sleepMinutesVal / sleepTargetVal, 1.0) : 0 %}
        {% set sleepDashoffset = circumference * (1 - sleepRatio) %}
        {% set sleepHours = (sleepMinutesVal // 60) %}
        {% set sleepMins  = (sleepMinutesVal % 60) %}
        {# Cardio ratio #}
        {% set cardioMinutesVal = cardioMinutes is defined ? cardioMinutes : 0 %}
        {% set cardioTargetVal  = cardioTarget  is defined ? cardioTarget  : 22 %}
        {% set cardioRatio = cardioTargetVal > 0 ? min(cardioMinutesVal / cardioTargetVal, 1.0) : 0 %}
        {% set cardioDashoffset = circumference * (1 - cardioRatio) %}

        <div class="mb-6 flex flex-wrap gap-8 justify-center items-start">

            {# Steps circle #}
            <div class="flex flex-col items-center">
                <div class="relative w-28 h-28">
                    <svg width="112" height="112" viewBox="0 0 120 120" class="-rotate-90">
                        <circle cx="60" cy="60" r="45" fill="none" stroke="currentColor" stroke-width="10"
                                class="text-gray-200 dark:text-gray-700"/>
                        <circle cx="60" cy="60" r="45" fill="none" stroke="currentColor" stroke-width="10"
                                stroke-linecap="round"
                                class="text-indigo-500 dark:text-indigo-400 transition-all duration-500"
                                stroke-dasharray="{{ circumference }}"
                                stroke-dashoffset="{{ stepsDashoffset }}"/>
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-lg font-bold text-gray-900 dark:text-gray-100">{{ todaySteps }}</span>
                        <span class="text-xs text-gray-500 dark:text-gray-400">pasos</span>
                    </div>
                </div>
                <p class="mt-2 text-xs text-gray-500 dark:text-gray-400 text-center">
                    {% if stepsTarget is not null and stepsTarget > 0 %}
                        de {{ stepsTarget|number_format(0, ',', '.') }} hoy
                    {% else %}
                        pasos hoy
                    {% endif %}
                </p>
                <a href="{{ path('daily_steps_index') }}"
                   class="mt-1 text-xs text-indigo-600 dark:text-indigo-400 hover:underline">Ver pasos &rarr;</a>
            </div>

            {# Sleep circle — only if fitbitToken valid #}
            {% set fitbitTokenForCircles = app.user.fitbitToken %}
            {% if fitbitTokenForCircles and fitbitTokenForCircles.isValid %}
            <div
                class="flex flex-col items-center"
                data-controller="sleep-chart"
                data-sleep-chart-url-value="{{ path('profile_sleep_data') }}"
            >
                <button
                    type="button"
                    data-action="click->sleep-chart#toggle"
                    class="relative w-28 h-28 focus:outline-none focus:ring-2 focus:ring-blue-400 rounded-full"
                    aria-label="Ver historial de sueño"
                >
                    <svg width="112" height="112" viewBox="0 0 120 120" class="-rotate-90">
                        <circle cx="60" cy="60" r="45" fill="none" stroke="currentColor" stroke-width="10"
                                class="text-gray-200 dark:text-gray-700"/>
                        <circle cx="60" cy="60" r="45" fill="none" stroke="currentColor" stroke-width="10"
                                stroke-linecap="round"
                                class="text-blue-500 dark:text-blue-400 transition-all duration-500"
                                stroke-dasharray="{{ circumference }}"
                                stroke-dashoffset="{{ sleepDashoffset }}"/>
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                        {% if sleepMinutesVal > 0 %}
                            <span class="text-base font-bold text-gray-900 dark:text-gray-100">{{ sleepHours }}h{{ sleepMins }}m</span>
                        {% else %}
                            <span class="text-base font-bold text-gray-400 dark:text-gray-500">—</span>
                        {% endif %}
                        <span class="text-xs text-gray-500 dark:text-gray-400">sueño</span>
                    </div>
                </button>
                <p class="mt-2 text-xs text-gray-500 dark:text-gray-400 text-center">de 8h anoche</p>
                <button type="button" data-action="click->sleep-chart#toggle"
                        class="mt-1 text-xs text-blue-600 dark:text-blue-400 hover:underline">
                    Ver historial
                </button>
                {# Expandable panel #}
                <div data-sleep-chart-target="panel"
                     class="hidden mt-4 w-72 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4 shadow-sm">
                    <h4 class="text-xs font-semibold text-gray-700 dark:text-gray-300 mb-3">Sueño — últimos 7 días</h4>
                    <div class="relative h-48">
                        <canvas data-sleep-chart-target="canvas"></canvas>
                    </div>
                    <p data-sleep-chart-target="empty"
                       class="hidden text-xs text-center text-gray-400 dark:text-gray-500 mt-4">Sin datos de sueño aún.</p>
                </div>
            </div>
            {% endif %}

            {# Cardio circle — only if fitbitToken valid #}
            {% if fitbitTokenForCircles and fitbitTokenForCircles.isValid %}
            <div
                class="flex flex-col items-center"
                data-controller="cardio-detail"
                data-cardio-detail-url-value="{{ path('profile_cardio_data') }}"
            >
                <button
                    type="button"
                    data-action="click->cardio-detail#toggle"
                    class="relative w-28 h-28 focus:outline-none focus:ring-2 focus:ring-orange-400 rounded-full"
                    aria-label="Ver historial cardio"
                >
                    <svg width="112" height="112" viewBox="0 0 120 120" class="-rotate-90">
                        <circle cx="60" cy="60" r="45" fill="none" stroke="currentColor" stroke-width="10"
                                class="text-gray-200 dark:text-gray-700"/>
                        <circle cx="60" cy="60" r="45" fill="none" stroke="currentColor" stroke-width="10"
                                stroke-linecap="round"
                                class="text-orange-500 dark:text-orange-400 transition-all duration-500"
                                stroke-dasharray="{{ circumference }}"
                                stroke-dashoffset="{{ cardioDashoffset }}"/>
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                        {% if cardioMinutesVal > 0 %}
                            <span class="text-base font-bold text-gray-900 dark:text-gray-100">{{ cardioMinutesVal }}m</span>
                        {% else %}
                            <span class="text-base font-bold text-gray-400 dark:text-gray-500">—</span>
                        {% endif %}
                        <span class="text-xs text-gray-500 dark:text-gray-400">cardio</span>
                    </div>
                </button>
                <p class="mt-2 text-xs text-gray-500 dark:text-gray-400 text-center">
                    {% if restingHR is defined and restingHR %}FC reposo: {{ restingHR }} bpm{% else %}de 22min objetivo{% endif %}
                </p>
                <button type="button" data-action="click->cardio-detail#toggle"
                        class="mt-1 text-xs text-orange-600 dark:text-orange-400 hover:underline">
                    Ver zonas
                </button>
                {# Expandable panel #}
                <div data-cardio-detail-target="panel"
                     class="hidden mt-4 w-72 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4 shadow-sm">
                    <h4 class="text-xs font-semibold text-gray-700 dark:text-gray-300 mb-1">Zonas cardíacas — últimos 7 días</h4>
                    {% if restingHR is defined and restingHR %}
                    <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">FC en reposo hoy: <span class="font-semibold text-gray-800 dark:text-gray-200">{{ restingHR }} bpm</span></p>
                    {% endif %}
                    <div class="relative h-48">
                        <canvas data-cardio-detail-target="canvas"></canvas>
                    </div>
                    <p data-cardio-detail-target="empty"
                       class="hidden text-xs text-center text-gray-400 dark:text-gray-500 mt-4">Sin datos cardíacos aún.</p>
                </div>
            </div>
            {% endif %}

        </div>

        {# ── Latest measurements summary card ────────────────────────────────── #}
        {% if latestMeasurement %}
        <div class="mb-6 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm px-6 py-4">
            <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-200 mb-3">Última medición — {{ latestMeasurement.measurementDate|date('d/m/Y') }}</h2>
            <div class="grid grid-cols-2 sm:grid-cols-5 gap-4">
                {% set fields = [
                    ['Peso', latestMeasurement.weightKg, 'kg'],
                    ['Pecho', latestMeasurement.chestCm, 'cm'],
                    ['Cintura', latestMeasurement.waistCm, 'cm'],
                    ['Caderas', latestMeasurement.hipsCm, 'cm'],
                    ['Brazos', latestMeasurement.armsCm, 'cm'],
                ] %}
                {% for field in fields %}
                    {% if field[1] is not null %}
                    <div class="text-center">
                        <p class="text-xs text-gray-500 dark:text-gray-400">{{ field[0] }}</p>
                        <p class="text-lg font-bold text-gray-900 dark:text-gray-100">{{ field[1] }} <span class="text-xs font-normal text-gray-400 dark:text-gray-500">{{ field[2] }}</span></p>
                    </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# ── Gráfica de evolución ──────────────────────────────────────────────── #}
        {% if measurements|length > 1 %}
        <div class="mt-6 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5"
             data-controller="measurement-chart"
             data-measurement-chart-url-value="{{ path('profile_measurement_list') }}"
             data-measurement-chart-fields-value="{{ ['weight_kg', 'chest_cm', 'waist_cm', 'hips_cm', 'arms_cm']|json_encode }}">
            <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-4">Evolución de medidas</h3>
            <div class="relative h-64">
                <canvas data-measurement-chart-target="canvas"></canvas>
            </div>
        </div>
        {% endif %}

        {# Measurements table with Stimulus pagination #}
        <div
            data-controller="measurement-pagination"
            data-measurement-pagination-url-value="{{ path('profile_measurement_list') }}"
            data-measurement-pagination-edit-url-value="{{ path('profile_measurement_edit', {id: '__ID__'}) }}"
            data-measurement-pagination-delete-url-value="{{ path('profile_measurement_delete', {id: '__ID__'}) }}"
        >
            <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-900/50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Fecha</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Peso (kg)</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Pecho (cm)</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Cintura (cm)</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Caderas (cm)</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Brazos (cm)</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Notas</th>
                            <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Acciones</th>
                        </tr>
                    </thead>
                    <tbody
                        class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-800"
                        data-measurement-pagination-target="tableBody"
                    >
                        {# Rows injected by Stimulus controller #}
                    </tbody>
                </table>
            </div>

            {# Empty state (shown by Stimulus when no items) #}
            <div
                class="hidden rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-6 py-12 text-center shadow-sm mt-2"
                data-measurement-pagination-target="emptyState"
            >
                <p class="text-sm text-gray-500 dark:text-gray-400">No tienes mediciones registradas todavía.</p>
                <a href="{{ path('profile_measurement_new') }}"
                   class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300">
                    + Añadir primera medición
                </a>
            </div>

            {# Pagination controls #}
            <nav class="mt-4 flex items-center justify-between" data-measurement-pagination-target="pagination">
                <div class="text-sm text-gray-500 dark:text-gray-400">
                    <span data-measurement-pagination-target="pageInfo">Cargando...</span>
                </div>
                <div class="flex gap-2">
                    <button
                        type="button"
                        data-measurement-pagination-target="prevButton"
                        data-action="click->measurement-pagination#prevPage"
                        class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 disabled:cursor-not-allowed disabled:opacity-50"
                    >
                        Anterior
                    </button>
                    <button
                        type="button"
                        data-measurement-pagination-target="nextButton"
                        data-action="click->measurement-pagination#nextPage"
                        class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 disabled:cursor-not-allowed disabled:opacity-50"
                    >
                        Siguiente
                    </button>
                </div>
            </nav>
        </div>


        {# ── Fitbit Integration ───────────────────────────────────────────────── #}
        {% if is_granted('ROLE_ATLETA') %}
        <div class="mt-6 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm p-6">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-4">Integración Fitbit</h3>
            {% set fitbitToken = app.user.fitbitToken %}
            {% if fitbitToken is null %}
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
                    Conecta tu cuenta de Fitbit para sincronizar automáticamente pasos, sueño y frecuencia cardíaca.
                </p>
                <a href="{{ path('fitbit_connect') }}"
                   class="inline-flex items-center rounded-md bg-[#00B0B9] px-4 py-2 text-sm font-semibold text-white hover:bg-[#009aa3]">
                    Conectar Fitbit
                </a>
            {% elseif not fitbitToken.isValid %}
                <div class="flex items-center gap-2 mb-3">
                    <span class="inline-flex items-center rounded-full bg-yellow-50 dark:bg-yellow-900/30 px-2.5 py-0.5 text-xs font-medium text-yellow-800 dark:text-yellow-300">
                        Token expirado
                    </span>
                </div>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
                    La conexión con Fitbit ha expirado. Vuelve a conectar tu cuenta.
                </p>
                <a href="{{ path('fitbit_connect') }}"
                   class="inline-flex items-center rounded-md bg-[#00B0B9] px-4 py-2 text-sm font-semibold text-white hover:bg-[#009aa3]">
                    Reconectar Fitbit
                </a>
            {% else %}
                <div class="flex items-center gap-2 mb-4">
                    <span class="inline-flex items-center rounded-full bg-green-50 dark:bg-green-900/30 px-2.5 py-0.5 text-xs font-medium text-green-700 dark:text-green-300">
                        Conectado
                    </span>
                    <span class="text-xs text-gray-500 dark:text-gray-400">
                        desde {{ fitbitToken.connectedAt|date('d/m/Y') }}
                    </span>
                </div>
                <div
                    data-controller="fitbit-sync"
                    data-fitbit-sync-url-value="{{ path('fitbit_sync') }}"
                    data-fitbit-sync-csrf-value="{{ csrf_token('fitbit_sync') }}"
                    class="mb-4"
                >
                    <button
                        type="button"
                        data-action="click->fitbit-sync#sync"
                        data-fitbit-sync-target="button"
                        class="inline-flex items-center gap-2 rounded-md bg-[#00B0B9] px-4 py-2 text-sm font-semibold text-white hover:bg-[#009aa3] disabled:opacity-60 disabled:cursor-not-allowed transition"
                    >
                        <span data-fitbit-sync-target="label">Sincronizar ahora</span>
                        <span data-fitbit-sync-target="spinner" class="hidden">
                            <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
                            </svg>
                        </span>
                    </button>
                    <p data-fitbit-sync-target="message" class="mt-2 text-sm hidden"></p>
                </div>
                <form method="post" action="{{ path('fitbit_disconnect') }}"
                      onsubmit="return confirm('¿Desconectar Fitbit? Los datos ya sincronizados se conservarán.')">
                    <input type="hidden" name="_token" value="{{ csrf_token('fitbit_disconnect') }}">
                    <button type="submit"
                            class="text-sm font-medium text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300">
                        Desconectar
                    </button>
                </form>
            {% endif %}
        </div>
        {% endif %}

        {% if is_granted('ROLE_ATLETA') %}
        <div class="mt-8">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100">Historial Reciente</h2>
                <a href="{{ path('history_index') }}" class="text-sm text-indigo-600 dark:text-indigo-400 hover:underline">Ver todo →</a>
            </div>
            {% if recentHistory|length > 0 %}
            <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
                    <thead class="bg-gray-50 dark:bg-gray-800">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Fecha</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Sesión</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Mesociclo</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Estado</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Duración</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
                        {% for log in recentHistory %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
                            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">{{ log.startTime|date('d/m/Y') }}</td>
                            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">{{ log.workoutSession.name }}</td>
                            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">{{ log.assignedMesocycle.mesocycle.title }}</td>
                            <td class="px-4 py-3">
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                                    {% if log.status.value == 'completed' %}bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200
                                    {% elseif log.status.value == 'in_progress' %}bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200
                                    {% else %}bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300{% endif %}">
                                    {{ log.status.value|replace({'_': ' '})|capitalize }}
                                </span>
                            </td>
                            <td class="px-4 py-3 text-gray-700 dark:text-gray-300">
                                {% if log.endTime %}
                                    {{ ((log.endTime.timestamp - log.startTime.timestamp) / 60)|round }} min
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <p class="text-sm text-gray-500 dark:text-gray-400">Aún no has completado ningún entrenamiento.</p>
            {% endif %}
        </div>
        {% endif %}

    </main>
</div>
{% endblock %}
