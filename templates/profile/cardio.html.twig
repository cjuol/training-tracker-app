{% extends 'base.html.twig' %}

{% block title %}Historial Cardio — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        {# Back link #}
        <a href="{{ path('profile_index') }}"
           class="inline-flex items-center gap-1 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 mb-6">
            &larr; Volver al perfil
        </a>

        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Historial Cardio</h1>

        {# Fitbit not connected guard #}
        {% if not fitbitToken or not fitbitToken.isValid %}
        <div class="rounded-lg bg-yellow-50 dark:bg-yellow-900/30 border border-yellow-200 dark:border-yellow-700 p-6 text-center">
            <p class="text-sm text-yellow-800 dark:text-yellow-300 mb-3">Conecta tu Fitbit para ver el historial cardíaco.</p>
            <a href="{{ path('fitbit_connect') }}"
               class="inline-flex items-center rounded-md bg-[#00B0B9] px-4 py-2 text-sm font-semibold text-white hover:bg-[#009aa3]">
                Conectar Fitbit
            </a>
        </div>
        {% else %}

        {# Cardio ring summary (today) #}
        {% set circumference = 282.74 %}
        {% set cardioMinutesVal = cardioMinutes is defined ? cardioMinutes : 0 %}
        {% set cardioTargetVal  = cardioTarget  is defined ? cardioTarget  : 22 %}
        {% set cardioRatio = cardioTargetVal > 0 ? min(cardioMinutesVal / cardioTargetVal, 1.0) : 0 %}
        {% set cardioDashoffset = circumference * (1 - cardioRatio) %}

        <div class="flex flex-col items-center mb-8">
            <div class="relative w-28 h-28">
                <svg width="112" height="112" viewBox="0 0 120 120" class="-rotate-90">
                    <circle cx="60" cy="60" r="45" fill="none" stroke="currentColor" stroke-width="10"
                            class="text-gray-200 dark:text-gray-700"/>
                    <circle cx="60" cy="60" r="45" fill="none" stroke="currentColor" stroke-width="10"
                            stroke-linecap="round"
                            class="text-orange-500 dark:text-orange-400 transition-all duration-500"
                            stroke-dasharray="{{ circumference }}"
                            stroke-dashoffset="{{ cardioDashoffset }}"/>
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    {% if cardioMinutesVal > 0 %}
                        <span class="text-base font-bold text-gray-900 dark:text-gray-100">{{ cardioMinutesVal }}m</span>
                    {% else %}
                        <span class="text-base font-bold text-gray-400 dark:text-gray-500">—</span>
                    {% endif %}
                    <span class="text-xs text-gray-500 dark:text-gray-400">cardio</span>
                </div>
            </div>
            {% if restingHR is defined and restingHR %}
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
                FC en reposo: <span class="font-semibold text-gray-800 dark:text-gray-200">{{ restingHR }} bpm</span>
            </p>
            {% else %}
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Objetivo: 22 min de zona cardio/peak</p>
            {% endif %}
        </div>

        {# Full chart — cardio-detail Stimulus controller, auto-loaded via inline script #}
        <div
            data-controller="cardio-detail"
            data-cardio-detail-url-value="{{ dataUrl }}"
            class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5"
        >
            <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4">Zonas cardíacas — últimos 30 días</h2>

            {# Hidden trigger for auto-load: panel starts hidden, script clicks this button after Stimulus connects #}
            <button type="button" id="cardio-auto-trigger"
                    class="sr-only"
                    data-action="click->cardio-detail#toggle">
                Cargar gráfica
            </button>

            <div data-cardio-detail-target="panel" class="hidden">
                <div class="relative h-64">
                    <canvas data-cardio-detail-target="canvas"></canvas>
                </div>
                <div data-cardio-detail-target="restingHr"
                     class="mt-3 text-xs text-gray-500 dark:text-gray-400">
                </div>
                <p data-cardio-detail-target="empty"
                   class="hidden text-xs text-center text-gray-400 dark:text-gray-500 mt-4">
                    Sin datos cardíacos aún.
                </p>
            </div>
        </div>

        <script>
            setTimeout(function() {
                var btn = document.getElementById('cardio-auto-trigger');
                if (btn) btn.click();
            }, 0);
        </script>

        {% endif %}

    </main>
</div>
{% endblock %}
