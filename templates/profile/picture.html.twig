{% extends 'base.html.twig' %}

{% block title %}Foto de Perfil — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <main class="max-w-lg mx-auto px-4 sm:px-6 lg:px-8 py-8">

        <div class="mb-6">
            <a href="{{ path('profile_index') }}" class="text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300">&larr; Volver al perfil</a>
        </div>

        <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm px-6 py-8">
            <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Foto de Perfil</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Sube una imagen JPEG, PNG o WebP (máx. 2 MB).</p>

            {# Current photo preview #}
            {% if app.user.profilePictureFilename %}
            <div class="mb-6 flex justify-center">
                <img
                    src="{{ '/uploads/profile_pictures/' ~ app.user.profilePictureFilename }}"
                    alt="Foto actual"
                    id="current-avatar"
                    class="w-32 h-32 rounded-full object-cover ring-2 ring-indigo-200"
                >
            </div>
            {% else %}
            <div class="mb-6 flex justify-center">
                <div id="avatar-preview" class="w-32 h-32 rounded-full bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center text-3xl font-bold text-indigo-600 dark:text-indigo-300 ring-2 ring-indigo-200 overflow-hidden">
                    {{ app.user.firstName|slice(0,1) }}{{ app.user.lastName|slice(0,1) }}
                </div>
            </div>
            {% endif %}

            {% for flash in app.flashes('success') %}
                <div class="mb-4 rounded-md bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 px-4 py-3 text-sm text-green-800 dark:text-green-300">
                    {{ flash }}
                </div>
            {% endfor %}

            {{ form_start(form, {attr: {enctype: 'multipart/form-data', class: 'space-y-4', id: 'picture-form'}}) }}

                <div>
                    {{ form_label(form.picture, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.picture, {attr: {
                        class: 'block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer',
                        id: 'picture-input'
                    }}) }}
                    {{ form_errors(form.picture) }}
                </div>

                <button
                    type="submit"
                    class="w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition">
                    Guardar foto
                </button>

            {{ form_end(form) }}

            {% if app.user.profilePictureFilename %}
            <div class="mt-4 border-t border-gray-100 dark:border-gray-700 pt-4">
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">¿Quieres eliminar tu foto de perfil actual?</p>
                <form method="post" action="{{ path('profile_picture_delete') }}"
                      onsubmit="return confirm('¿Seguro que quieres eliminar tu foto de perfil?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_profile_picture') }}">
                    <button type="submit"
                            class="rounded-md border border-red-300 dark:border-red-700 bg-white dark:bg-gray-800 px-4 py-2 text-sm font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition">
                        Eliminar foto
                    </button>
                </form>
            </div>
            {% endif %}
        </div>

    </main>
</div>

<script>
    (function () {
        var input = document.getElementById('picture-input');
        if (!input) { return; }

        input.addEventListener('change', function () {
            var file = this.files && this.files[0];
            if (!file) { return; }

            var reader = new FileReader();
            reader.onload = function (e) {
                var preview = document.getElementById('avatar-preview') || document.getElementById('current-avatar');
                if (!preview) { return; }

                var img = document.createElement('img');
                img.src = e.target.result;
                img.className = 'w-32 h-32 rounded-full object-cover ring-2 ring-indigo-200';
                img.id = 'current-avatar';
                preview.parentNode.replaceChild(img, preview);
            };
            reader.readAsDataURL(file);
        });
    }());
</script>
{% endblock %}
