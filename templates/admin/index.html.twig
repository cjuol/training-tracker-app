{% extends 'base.html.twig' %}

{% block title %}Panel de Administración — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">

        {# Header #}
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-gray-900">Panel de Administración</h1>
            <p class="mt-1 text-sm text-gray-500">Gestión de usuarios y vínculos entrenador–atleta.</p>
        </div>

        {# ------------------------------------------------------------------ #}
        {# Section 1: Users table                                              #}
        {# ------------------------------------------------------------------ #}
        <div class="mb-10">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">Usuarios</h2>
            <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
                <table class="min-w-full divide-y divide-gray-200 text-sm">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">ID</th>
                            <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Email</th>
                            <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Nombre</th>
                            <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Apellido</th>
                            <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Roles</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 bg-white">
                        {% for user in users %}
                            <tr class="hover:bg-gray-50">
                                <td class="px-4 py-3 text-gray-500">{{ user.id }}</td>
                                <td class="px-4 py-3 font-medium text-gray-900">{{ user.email }}</td>
                                <td class="px-4 py-3 text-gray-700">{{ user.firstName }}</td>
                                <td class="px-4 py-3 text-gray-700">{{ user.lastName }}</td>
                                <td class="px-4 py-3">
                                    {% for role in user.roles %}
                                        {% if role != 'ROLE_USER' %}
                                            <span class="inline-block rounded px-2 py-0.5 text-xs font-semibold
                                                {% if role == 'ROLE_ADMIN' %}bg-red-100 text-red-700
                                                {% elseif role == 'ROLE_ENTRENADOR' %}bg-indigo-100 text-indigo-700
                                                {% else %}bg-green-100 text-green-700{% endif %}">
                                                {{ role }}
                                            </span>
                                        {% endif %}
                                    {% endfor %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="px-4 py-6 text-center text-gray-400">No hay usuarios registrados.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# ------------------------------------------------------------------ #}
        {# Section 2: CoachAthlete links table                                 #}
        {# ------------------------------------------------------------------ #}
        <div class="mb-10">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">Vínculos Entrenador–Atleta</h2>
            <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
                <table class="min-w-full divide-y divide-gray-200 text-sm">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">ID</th>
                            <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Entrenador</th>
                            <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Atleta</th>
                            <th class="px-4 py-3 text-left font-medium text-gray-500 uppercase tracking-wider">Acción</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 bg-white">
                        {% for link in links %}
                            <tr class="hover:bg-gray-50">
                                <td class="px-4 py-3 text-gray-500">{{ link.id }}</td>
                                <td class="px-4 py-3 font-medium text-gray-900">{{ link.coach.email }}</td>
                                <td class="px-4 py-3 text-gray-700">{{ link.athlete.email }}</td>
                                <td class="px-4 py-3">
                                    <form method="post"
                                          action="{{ path('admin_delete_link', {id: link.id}) }}"
                                          onsubmit="return confirm('¿Eliminar este vínculo?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_link_' ~ link.id) }}">
                                        <button type="submit"
                                                class="text-sm font-medium text-red-600 hover:text-red-900">
                                            Eliminar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="px-4 py-6 text-center text-gray-400">No hay vínculos registrados.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# ------------------------------------------------------------------ #}
        {# Section 3: Create new CoachAthlete link                            #}
        {# ------------------------------------------------------------------ #}
        <div class="rounded-lg border border-gray-200 bg-white shadow-sm p-6">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">Crear nuevo vínculo</h2>
            <form method="post" action="{{ path('admin_create_link') }}" class="flex flex-wrap items-end gap-4">
                <input type="hidden" name="_token" value="{{ csrf_token('create_link') }}">

                <div class="flex flex-col gap-1">
                    <label for="coach_id" class="text-sm font-medium text-gray-700">Entrenador</label>
                    <select id="coach_id" name="coach_id"
                            class="rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
                        <option value="">— Selecciona un entrenador —</option>
                        {% for coach in coaches %}
                            <option value="{{ coach.id }}">{{ coach.email }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="flex flex-col gap-1">
                    <label for="athlete_id" class="text-sm font-medium text-gray-700">Atleta</label>
                    <select id="athlete_id" name="athlete_id"
                            class="rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500">
                        <option value="">— Selecciona un atleta —</option>
                        {% for user in users %}
                            <option value="{{ user.id }}">{{ user.email }}</option>
                        {% endfor %}
                    </select>
                </div>

                <button type="submit"
                        class="inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                    Crear vínculo
                </button>
            </form>
        </div>

    </div>
</div>
{% endblock %}
