{#
  Partial: a single session-exercise row.
  Variables: sessionExercise (SessionExercise entity), session (WorkoutSession entity)
#}
<div class="flex items-center justify-between gap-3 rounded bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 px-3 py-2 cursor-grab active:cursor-grabbing"
     data-sortable-target="item"
     data-id="{{ sessionExercise.id }}"
     data-session-id="{{ session.id }}"
     draggable="true">

    {# Drag handle icon #}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
    </svg>

    <div class="flex-1 min-w-0">
        <span class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate">{{ sessionExercise.exercise.name }}</span>
        <div class="mt-0.5 flex flex-wrap items-center gap-1.5">
            {# Measurement type badge #}
            <span class="inline-flex items-center rounded-full bg-indigo-50 dark:bg-indigo-900/40 px-2 py-0.5 text-xs font-medium text-indigo-700 dark:text-indigo-300">
                {{ sessionExercise.exercise.measurementType.label() }}
            </span>
            {# Series type badge #}
            <span class="inline-flex items-center rounded-full bg-amber-50 dark:bg-amber-900/40 px-2 py-0.5 text-xs font-medium text-amber-700 dark:text-amber-300">
                {{ sessionExercise.seriesType.label() }}
            </span>
            {# Target info #}
            <span class="text-xs text-gray-500 dark:text-gray-400">
                {{ sessionExercise.targetSets }} series
                {% if sessionExercise.targetReps %} &times; {{ sessionExercise.targetReps }} reps{% endif %}
                {% if sessionExercise.targetWeight %} @ {{ sessionExercise.targetWeight }} kg{% endif %}
            </span>
            {% if sessionExercise.superseriesGroup %}
                <span class="inline-flex items-center rounded-full bg-purple-50 dark:bg-purple-900/40 px-2 py-0.5 text-xs font-medium text-purple-700 dark:text-purple-300">
                    Grupo {{ sessionExercise.superseriesGroup }}
                </span>
            {% endif %}
        </div>
    </div>

    {# Actions #}
    <div class="flex items-center gap-2 shrink-0">
        <a href="{{ path('session_exercise_edit', {sessionId: session.id, id: sessionExercise.id}) }}"
           class="text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-300">
            Editar
        </a>
        <form method="post"
              action="{{ path('session_exercise_delete', {sessionId: session.id, id: sessionExercise.id}) }}"
              onsubmit="return confirm('¿Eliminar este ejercicio de la sesión?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete-exercise-' ~ sessionExercise.id) }}">
            <button type="submit" class="text-xs font-medium text-red-600 hover:text-red-900">Quitar</button>
        </form>
    </div>
</div>
