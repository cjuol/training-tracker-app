{% extends 'base.html.twig' %}

{% block title %}Mis Mesociclos — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 rounded-md {{ type == 'success' ? 'bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 text-green-800 dark:text-green-300' : 'bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 text-red-800 dark:text-red-300' }} px-4 py-3 text-sm">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Header #}
        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Mis Mesociclos</h1>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Gestiona tus plantillas de entrenamiento.</p>
            </div>
            <a href="{{ path('mesocycle_new') }}"
               class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Nuevo Mesociclo
            </a>
        </div>

        {# Mesocycles grid #}
        {% if mesocycles is empty %}
            <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-6 py-12 text-center shadow-sm">
                <p class="text-sm text-gray-500 dark:text-gray-400">No tienes mesociclos creados todavía.</p>
                <a href="{{ path('mesocycle_new') }}" class="mt-2 inline-block text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">
                    Crea tu primer mesociclo
                </a>
            </div>
        {% else %}
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {% for mesocycle in mesocycles %}
                    <div class="flex flex-col rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm overflow-hidden">
                        <div class="flex-1 p-6">
                            <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">{{ mesocycle.title }}</h2>
                            {% if mesocycle.description %}
                                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 line-clamp-3">{{ mesocycle.description }}</p>
                            {% endif %}
                            <p class="mt-3 text-xs text-gray-400 dark:text-gray-500">
                                {{ mesocycle.workoutSessions|length }} sesión{{ mesocycle.workoutSessions|length != 1 ? 'es' : '' }}
                                &middot; creado {{ mesocycle.createdAt|date('d/m/Y') }}
                            </p>
                        </div>
                        <div class="border-t border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 px-6 py-3 flex items-center justify-between gap-2">
                            <a href="{{ path('mesocycle_show', {id: mesocycle.id}) }}"
                               class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">
                                Ver
                            </a>
                            <a href="{{ path('mesocycle_edit', {id: mesocycle.id}) }}"
                               class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100">
                                Editar
                            </a>
                            <form method="post"
                                  action="{{ path('mesocycle_delete', {id: mesocycle.id}) }}"
                                  onsubmit="return confirm('¿Eliminar el mesociclo «{{ mesocycle.title }}»? Esta acción no se puede deshacer.');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-mesocycle-' ~ mesocycle.id) }}">
                                <button type="submit" class="text-sm font-medium text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300">
                                    Eliminar
                                </button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}
