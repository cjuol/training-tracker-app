{% extends 'base.html.twig' %}

{% block title %}{{ athlete.firstName }} {{ athlete.lastName }} — {{ mesocycle.title }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-8">
    {# Breadcrumb #}
    <nav class="text-sm text-gray-500 dark:text-gray-400 mb-6">
        <a href="{{ path('mesocycle_index') }}" class="hover:text-indigo-600 dark:hover:text-indigo-400">Mesociclos</a>
        <span class="mx-2">/</span>
        <a href="{{ path('mesocycle_show', {id: mesocycle.id}) }}" class="hover:text-indigo-600 dark:hover:text-indigo-400">{{ mesocycle.title }}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-800 dark:text-gray-200">{{ athlete.firstName }} {{ athlete.lastName }}</span>
    </nav>

    <div class="flex items-center gap-4 mb-6">
        <div class="w-12 h-12 rounded-full bg-indigo-500 flex items-center justify-center text-white font-bold text-lg">
            {{ athlete.firstName|first|upper }}{{ athlete.lastName|first|upper }}
        </div>
        <div>
            <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100">{{ athlete.firstName }} {{ athlete.lastName }}</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400">{{ mesocycle.title }}</p>
        </div>
        {% for assignment in assignments %}
        <span class="ml-auto inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
            {% if assignment.status == constant('App\\Enum\\AssignmentStatus::Active') %}bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200
            {% elseif assignment.status == constant('App\\Enum\\AssignmentStatus::Cancelled') %}bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200
            {% else %}bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300{% endif %}">
            {{ assignment.status.label() }}
        </span>
        {% endfor %}
    </div>

    <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-4">Entrenamientos realizados</h2>
    {% if logs|length > 0 %}
    <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
            <thead class="bg-gray-50 dark:bg-gray-800">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Fecha</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Sesión</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Estado</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Duración</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Series</th>
                </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
                {% for log in logs %}
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800">
                    <td class="px-4 py-3 text-gray-700 dark:text-gray-300">{{ log.startTime|date('d/m/Y') }}</td>
                    <td class="px-4 py-3 text-gray-700 dark:text-gray-300">{{ log.workoutSession.name }}</td>
                    <td class="px-4 py-3">
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                            {% if log.status.value == 'completed' %}bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200
                            {% elseif log.status.value == 'in_progress' %}bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200
                            {% else %}bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300{% endif %}">
                            {{ log.status.value|replace({'_': ' '})|capitalize }}
                        </span>
                    </td>
                    <td class="px-4 py-3 text-gray-700 dark:text-gray-300">
                        {% if log.endTime %}
                            {{ ((log.endTime.timestamp - log.startTime.timestamp) / 60)|round }} min
                        {% else %}—{% endif %}
                    </td>
                    <td class="px-4 py-3 text-gray-700 dark:text-gray-300">{{ log.setLogs|length }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <p class="text-sm text-gray-500 dark:text-gray-400">Este atleta aún no ha registrado entrenamientos para este mesociclo.</p>
    {% endif %}
</div>
{% endblock %}
