{% extends 'base.html.twig' %}

{% block title %}{{ mesocycle.title }} — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-8">

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 rounded-md {{ type == 'success' ? 'bg-green-50 border border-green-200 text-green-800' : 'bg-red-50 border border-red-200 text-red-800' }} px-4 py-3 text-sm">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Breadcrumb #}
        <nav class="mb-6 flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
            <a href="{{ path('mesocycle_index') }}" class="hover:text-gray-700 dark:hover:text-gray-300">Mesociclos</a>
            <span>/</span>
            <span class="text-gray-900 dark:text-gray-100 font-medium">{{ mesocycle.title }}</span>
        </nav>

        {# Mesocycle header #}
        <div class="mb-6 flex items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">{{ mesocycle.title }}</h1>
                {% if mesocycle.description %}
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{{ mesocycle.description }}</p>
                {% endif %}
            </div>
            <div class="flex items-center gap-3 shrink-0">
                <a href="{{ path('mesocycle_edit', {id: mesocycle.id}) }}"
                   class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700/50 shadow-sm">
                    Editar mesociclo
                </a>
                <a href="{{ path('workout_session_new', {mesocycleId: mesocycle.id}) }}"
                   class="inline-flex items-center gap-1 rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">
                    + Añadir sesión
                </a>
            </div>
        </div>

        {# ── Atletas Asignados ─────────────────────────────────────────────── #}
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4 mb-6 flex flex-col sm:flex-row sm:items-center gap-4">

            {# Left: athlete avatars #}
            <div class="flex-1">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">Atletas asignados</p>
                {% if assignedAthletes|length > 0 %}
                    <div class="flex items-center gap-1 flex-wrap">
                        {% set colorClasses = ['bg-indigo-500','bg-violet-500','bg-sky-500','bg-emerald-500','bg-amber-500','bg-rose-500','bg-teal-500','bg-orange-500'] %}
                        {% set maxVisible = 6 %}
                        {% for athlete in assignedAthletes|slice(0, maxVisible) %}
                            {% set colorClass = colorClasses[athlete.id % 8] %}
                            <a href="{{ path('mesocycle_athlete_stats', {id: mesocycle.id, athleteId: athlete.id}) }}"
                               class="group relative flex items-center justify-center w-8 h-8 rounded-full {{ colorClass }} text-white text-xs font-bold hover:ring-2 hover:ring-offset-1 hover:ring-indigo-400 transition"
                               title="{{ athlete.firstName }} {{ athlete.lastName }}">
                                {{ athlete.firstName|first|upper }}{{ athlete.lastName|first|upper }}
                                <span class="pointer-events-none absolute bottom-full mb-1 left-1/2 -translate-x-1/2 whitespace-nowrap rounded bg-gray-900 px-2 py-1 text-xs text-white opacity-0 group-hover:opacity-100 transition-opacity z-10">
                                    {{ athlete.firstName }} {{ athlete.lastName }}
                                </span>
                            </a>
                        {% endfor %}
                        {% if assignedAthletes|length > maxVisible %}
                            <button type="button"
                                    onclick="document.getElementById('athletes-modal-{{ mesocycle.id }}').classList.remove('hidden'); document.body.classList.add('overflow-hidden')"
                                    class="flex items-center justify-center w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-600 text-gray-600 dark:text-gray-300 text-xs font-bold hover:bg-gray-300 dark:hover:bg-gray-500 transition">
                                +{{ assignedAthletes|length - maxVisible }}
                            </button>
                        {% endif %}
                    </div>
                {% else %}
                    <p class="text-sm text-gray-400 dark:text-gray-500">Ningún atleta asignado aún.</p>
                {% endif %}
            </div>

            {# Divider #}
            <div class="hidden sm:block w-px h-12 bg-gray-200 dark:bg-gray-700"></div>

            {# Right: invite code #}
            <div class="flex flex-col gap-1 sm:items-end">
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Código de invitación</p>
                <div class="flex items-center gap-2">
                    <code id="invite-code-{{ mesocycle.id }}" class="px-3 py-1 bg-gray-100 dark:bg-gray-700 text-indigo-700 dark:text-indigo-300 rounded font-mono text-sm tracking-widest select-all">{{ mesocycle.inviteCode }}</code>
                    {# Copy button #}
                    <button type="button"
                            data-controller="clipboard-copy"
                            data-clipboard-copy-target-value="#invite-code-{{ mesocycle.id }}"
                            data-action="click->clipboard-copy#copy"
                            title="Copiar código"
                            class="p-1.5 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                        </svg>
                    </button>
                    {# Regenerate button #}
                    <form method="post" action="{{ path('mesocycle_regenerate_code', {id: mesocycle.id}) }}"
                          onsubmit="return confirm('¿Regenerar el código? Se cancelarán {{ assignedAthletes|length }} asignación(es) activa(s).')">
                        <input type="hidden" name="_token" value="{{ csrf_token('regenerate-code-' ~ mesocycle.id) }}">
                        <button type="submit"
                                title="Regenerar código"
                                class="p-1.5 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-red-50 dark:hover:bg-red-900 hover:text-red-600 dark:hover:text-red-400 transition">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        {# Sessions list — sortable #}
        {% set reorderSessionsUrl = path('workout_session_reorder', {mesocycleId: mesocycle.id}) %}

        {% if sessions is empty %}
            <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-6 py-12 text-center shadow-sm">
                <p class="text-sm text-gray-500 dark:text-gray-400">Este mesociclo no tiene sesiones todavía.</p>
                <a href="{{ path('workout_session_new', {mesocycleId: mesocycle.id}) }}"
                   class="mt-2 inline-block text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">
                    Añade la primera sesión
                </a>
            </div>
        {% else %}
            <div class="space-y-4"
                 data-controller="sortable"
                 data-sortable-url-value="{{ reorderSessionsUrl }}"
                 data-sortable-csrf-value="{{ csrf_token('reorder_workout_sessions') }}">
                {% for session in sessions %}
                    {% include 'mesocycle/_session_card.html.twig' with {session: session, mesocycle: mesocycle} %}
                {% endfor %}
            </div>
            <p class="mt-4 text-xs text-gray-400 dark:text-gray-500">Arrastra las sesiones para reordenarlas.</p>
        {% endif %}

    </div>
</div>

{# Athletes modal #}
{% if assignedAthletes|length > 6 %}
<div id="athletes-modal-{{ mesocycle.id }}"
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/50"
         onclick="document.getElementById('athletes-modal-{{ mesocycle.id }}').classList.add('hidden'); document.body.classList.remove('overflow-hidden')"></div>
    <div class="relative bg-white dark:bg-gray-800 rounded-xl shadow-xl w-full max-w-md p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Todos los atletas</h3>
            <button type="button"
                    onclick="document.getElementById('athletes-modal-{{ mesocycle.id }}').classList.add('hidden'); document.body.classList.remove('overflow-hidden')"
                    class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="flex flex-wrap gap-3">
            {% set colorClasses = ['bg-indigo-500','bg-violet-500','bg-sky-500','bg-emerald-500','bg-amber-500','bg-rose-500','bg-teal-500','bg-orange-500'] %}
            {% for athlete in assignedAthletes %}
                {% set colorClass = colorClasses[athlete.id % 8] %}
                <a href="{{ path('mesocycle_athlete_stats', {id: mesocycle.id, athleteId: athlete.id}) }}"
                   class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                    <span class="flex-shrink-0 w-8 h-8 rounded-full {{ colorClass }} flex items-center justify-center text-white text-xs font-bold">
                        {{ athlete.firstName|first|upper }}{{ athlete.lastName|first|upper }}
                    </span>
                    <span class="text-sm text-gray-700 dark:text-gray-300">{{ athlete.firstName }} {{ athlete.lastName }}</span>
                </a>
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
