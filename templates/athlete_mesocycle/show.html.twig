{% extends 'base.html.twig' %}

{% block title %}{{ mesocycle.title }} — Mis Mesociclos{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 py-8">

    {# ── Back link ── #}
    <a href="{{ path('athlete_mesocycles_index') }}"
       class="inline-flex items-center gap-1 text-sm text-indigo-600 dark:text-indigo-400 hover:underline mb-6">
        &larr; Mis Mesociclos
    </a>

    {# ── Mesocycle header ── #}
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 mb-6">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-1">{{ mesocycle.title }}</h1>
        {% if mesocycle.description %}
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">{{ mesocycle.description }}</p>
        {% endif %}
        <dl class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
            <div>
                <dt class="text-xs text-gray-500 dark:text-gray-400 uppercase font-medium">Entrenador</dt>
                <dd class="font-semibold text-gray-800 dark:text-gray-200 mt-0.5">{{ mesocycle.coach.fullName }}</dd>
            </div>
            <div>
                <dt class="text-xs text-gray-500 dark:text-gray-400 uppercase font-medium">Inicio</dt>
                <dd class="font-semibold text-gray-800 dark:text-gray-200 mt-0.5">{{ assignment.startDate|date('d/m/Y') }}</dd>
            </div>
            {% if assignment.endDate %}
            <div>
                <dt class="text-xs text-gray-500 dark:text-gray-400 uppercase font-medium">Fin</dt>
                <dd class="font-semibold text-gray-800 dark:text-gray-200 mt-0.5">{{ assignment.endDate|date('d/m/Y') }}</dd>
            </div>
            {% endif %}
            {% if mesocycle.dailyStepsTarget %}
            <div>
                <dt class="text-xs text-gray-500 dark:text-gray-400 uppercase font-medium">Objetivo pasos</dt>
                <dd class="font-semibold text-gray-800 dark:text-gray-200 mt-0.5">{{ mesocycle.dailyStepsTarget|number_format(0, ',', '.') }}/día</dd>
            </div>
            {% endif %}
            <div>
                <dt class="text-xs text-gray-500 dark:text-gray-400 uppercase font-medium">Estado</dt>
                <dd class="mt-0.5">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                        {% if assignment.status == constant('App\\Enum\\AssignmentStatus::Active') %}bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300
                        {% elseif assignment.status == constant('App\\Enum\\AssignmentStatus::Completed') %}bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300
                        {% else %}bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300{% endif %}">
                        {{ assignment.status.label() }}
                    </span>
                </dd>
            </div>
        </dl>
    </div>

    {# ── Sessions list ── #}
    <h2 class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-4">Sesiones de entrenamiento</h2>

    {% if sessions is empty %}
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 px-6 py-10 text-center">
            <p class="text-sm text-gray-400 dark:text-gray-500 italic">Este mesociclo no tiene sesiones todavía.</p>
        </div>
    {% else %}
        {% set days = {1: 'Lunes', 2: 'Martes', 3: 'Miércoles', 4: 'Jueves', 5: 'Viernes', 6: 'Sábado', 7: 'Domingo'} %}
        <div class="space-y-4">
        {% for session in sessions %}
            <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">

                {# Session header #}
                <div class="flex items-center justify-between px-5 py-4 bg-indigo-50 dark:bg-indigo-950 border-b border-indigo-100 dark:border-indigo-900">
                    <div>
                        <h3 class="font-semibold text-indigo-900 dark:text-indigo-200">{{ session.name }}</h3>
                        {% if session.dayOfWeek %}
                            <p class="text-xs text-indigo-600 dark:text-indigo-400 mt-0.5">{{ days[session.dayOfWeek] ?? '' }}</p>
                        {% endif %}
                    </div>
                    <div>
                        {% if inProgressMap[session.id] is defined %}
                            <a href="{{ path('workout_show', {workoutLogId: inProgressMap[session.id]}) }}"
                               class="inline-flex items-center rounded-md bg-yellow-500 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-yellow-400 active:bg-yellow-600 transition">
                                Continuar
                            </a>
                        {% else %}
                            <form method="POST"
                                  action="{{ path('workout_start', {assignedMesocycleId: assignment.id, sessionId: session.id}) }}">
                                <button type="submit"
                                        class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 active:bg-indigo-700 transition">
                                    Iniciar
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>

                {# Exercises list #}
                {% set exercises = session.orderedExercises %}
                {% if exercises is empty %}
                    <div class="px-5 py-3">
                        <p class="text-xs text-gray-400 dark:text-gray-500 italic">Sin ejercicios aún.</p>
                    </div>
                {% else %}
                    <ul class="divide-y divide-gray-100 dark:divide-gray-700">
                    {% for se in exercises %}
                        <li class="flex items-center justify-between px-5 py-3">
                            <div>
                                <p class="text-sm font-medium text-gray-800 dark:text-gray-200">{{ se.exercise.name }}</p>
                                <p class="text-xs text-gray-500 dark:text-gray-400">
                                    {{ se.targetSets }} series
                                    {% if se.targetReps %} × {{ se.targetReps }} reps{% endif %}
                                    {% if se.targetWeight %} — {{ se.targetWeight }} kg{% endif %}
                                </p>
                            </div>
                            <span class="text-xs text-gray-400 dark:text-gray-500 font-mono uppercase">
                                {{ se.seriesType.value }}
                            </span>
                        </li>
                    {% endfor %}
                    </ul>
                {% endif %}

            </div>
        {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
