{% extends 'base.html.twig' %}

{% block title %}Mis Pasos — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        {# ── Flash messages ──────────────────────────────────────────────────── #}
        {% for flash in app.flashes('success') %}
            <div class="mb-4 rounded-md bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 px-4 py-3 text-sm text-green-800 dark:text-green-300">
                {{ flash }}
            </div>
        {% endfor %}
        {% for flash in app.flashes('error') %}
            <div class="mb-4 rounded-md bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 px-4 py-3 text-sm text-red-800 dark:text-red-300">
                {{ flash }}
            </div>
        {% endfor %}

        {# ── Page header ──────────────────────────────────────────────────────── #}
        <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Mis Pasos</h1>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Registra tus pasos diarios y consulta tu historial reciente.</p>
            </div>
            <div class="flex gap-2">
                {% for option in [7, 30, 90] %}
                    <a href="{{ path('daily_steps_index', {days: option}) }}"
                       class="px-3 py-1 rounded text-sm {{ days == option ? 'bg-indigo-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' }} transition">
                        {{ option }} días
                    </a>
                {% endfor %}
            </div>
        </div>

        {# ── Today's form card ────────────────────────────────────────────────── #}
        <div class="mb-8 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm px-6 py-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1">Registrar pasos de hoy</h2>
            {% if todayEntry %}
                <p class="text-sm text-green-700 dark:text-green-400 mb-4">
                    Ya registraste <strong>{{ todayEntry.steps|number_format(0, ',', '.') }}</strong> pasos hoy. Puedes actualizarlos a continuación.
                </p>
            {% else %}
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Todavía no has registrado pasos para hoy.</p>
            {% endif %}

            {{ form_start(form, {action: path('daily_steps_upsert'), method: 'POST', attr: {class: 'space-y-4'}}) }}

                <div>
                    {{ form_label(form.date, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                    {{ form_widget(form.date, {attr: {class: 'dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100'}}) }}
                    {{ form_errors(form.date) }}
                </div>

                <div>
                    {{ form_label(form.steps, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                    {{ form_widget(form.steps, {attr: {class: 'dark:bg-gray-800 dark:border-gray-600 dark:text-gray-100'}}) }}
                    {{ form_errors(form.steps) }}
                </div>

                <button type="submit"
                        class="inline-flex justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition">
                    Guardar
                </button>

            {{ form_end(form) }}
        </div>

        {# ── Recent history ───────────────────────────────────────────────────── #}
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
                <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">Historial — últimos {{ days }} días</h2>
            </div>

            {% if recentSteps is empty %}
                <div class="px-6 py-10 text-center">
                    <p class="text-sm text-gray-500 dark:text-gray-400">No hay registros de pasos en los últimos {{ days }} días.</p>
                </div>
            {% else %}
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-900/50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Fecha</th>
                            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Pasos</th>
                            <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-800">
                        {% for entry in recentSteps %}
                            <tr>
                                <td class="px-6 py-3 text-sm text-gray-700 dark:text-gray-300">{{ entry.date|date('d/m/Y') }}</td>
                                <td class="px-6 py-3 text-sm font-medium text-gray-900 dark:text-gray-100">{{ entry.steps|number_format(0, ',', '.') }}</td>
                                <td class="px-6 py-3 text-right">
                                    <form method="post"
                                          action="{{ path('daily_steps_delete', {id: entry.id}) }}"
                                          onsubmit="return confirm('¿Eliminar esta entrada?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_steps_' ~ entry.id) }}">
                                        <button type="submit"
                                                class="text-xs text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 underline">
                                            Eliminar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>

    </main>
</div>
{% endblock %}
