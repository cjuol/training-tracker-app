{% extends 'base.html.twig' %}

{% block title %}Catálogo de Ejercicios — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 rounded-md {{ type == 'success' ? 'bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 text-green-800 dark:text-green-300' : 'bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 text-red-800 dark:text-red-300' }} px-4 py-3 text-sm">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Header #}
        <div class="mb-6 flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Catálogo de Ejercicios</h1>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Gestiona los ejercicios disponibles para tus mesociclos.</p>
            </div>
            <a href="{{ path('exercise_new') }}"
               class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Nuevo Ejercicio
            </a>
        </div>

        {# Search input with Stimulus controller #}
        <div class="mb-6" data-controller="exercise-search">
            <label for="exercise-search-input" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Buscar ejercicio</label>
            <input
                type="search"
                id="exercise-search-input"
                data-exercise-search-target="input"
                data-action="input->exercise-search#filter"
                value="{{ search ?? '' }}"
                placeholder="Filtrar por nombre..."
                class="block w-full max-w-md rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-100 dark:placeholder-gray-500 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
            />
        </div>

        {# Exercises table #}
        <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm">
            {% if exercises is empty %}
                <div class="px-6 py-12 text-center">
                    <p class="text-sm text-gray-500 dark:text-gray-400">No hay ejercicios creados todavía.</p>
                    <a href="{{ path('exercise_new') }}" class="mt-2 inline-block text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">
                        Crea el primer ejercicio
                    </a>
                </div>
            {% else %}
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700" data-exercise-search-target="table">
                    <thead class="bg-gray-50 dark:bg-gray-900/50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">
                                Nombre
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">
                                Tipo de Medición
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">
                                Creado por
                            </th>
                            <th scope="col" class="relative px-6 py-3">
                                <span class="sr-only">Acciones</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700 bg-white dark:bg-gray-800">
                        {% for exercise in exercises %}
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700" data-exercise-name="{{ exercise.name | lower }}">
                                <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-gray-900 dark:text-gray-100">
                                    {{ exercise.name }}
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500 dark:text-gray-400">
                                    <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700">
                                        {{ exercise.measurementType.label() }}
                                    </span>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500 dark:text-gray-400">
                                    {{ exercise.createdBy.fullName }}
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-medium">
                                    <div class="flex items-center justify-end gap-3">
                                        {% if is_granted('EXERCISE_EDIT', exercise) %}
                                            <a href="{{ path('exercise_edit', {id: exercise.id}) }}"
                                               class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-300">
                                                Editar
                                            </a>
                                        {% endif %}
                                        {% if is_granted('EXERCISE_DELETE', exercise) %}
                                            <form method="post"
                                                  action="{{ path('exercise_delete', {id: exercise.id}) }}"
                                                  onsubmit="return confirm('¿Eliminar este ejercicio?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete-exercise-' ~ exercise.id) }}">
                                                <button type="submit"
                                                        class="text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300">
                                                    Eliminar
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>

        <p class="mt-4 text-xs text-gray-400 dark:text-gray-500">
            {{ exercises | length }} ejercicio{{ exercises | length != 1 ? 's' : '' }} en total.
        </p>
    </div>
</div>
{% endblock %}
