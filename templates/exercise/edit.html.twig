{% extends 'base.html.twig' %}

{% block title %}Editar Ejercicio — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 py-8">

        {# Breadcrumb #}
        <nav class="mb-6 flex items-center gap-2 text-sm text-gray-500">
            <a href="{{ path('exercise_index') }}" class="hover:text-gray-700">Ejercicios</a>
            <span>/</span>
            <span class="text-gray-900 font-medium">{{ exercise.name }}</span>
        </nav>

        <div class="bg-white rounded-lg border border-gray-200 shadow-sm">
            <div class="px-6 py-5 border-b border-gray-200">
                <h1 class="text-lg font-semibold text-gray-900">Editar Ejercicio</h1>
                <p class="mt-1 text-sm text-gray-500">Modifica los datos del ejercicio <strong>{{ exercise.name }}</strong>.</p>
            </div>
            <div class="px-6 py-6">
                {% include 'exercise/_form.html.twig' %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
