{% extends 'base.html.twig' %}

{% block title %}Pasos de {{ athlete.fullName }} — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        {# Breadcrumb #}
        <nav class="mb-4 text-sm text-gray-500 dark:text-gray-400">
            <a href="{{ path('app_dashboard') }}" class="hover:text-indigo-600 dark:hover:text-indigo-400">Panel</a>
            <span class="mx-1">/</span>
            <a href="{{ path('coach_athlete_history', {athleteId: athlete.id}) }}"
               class="hover:text-indigo-600 dark:hover:text-indigo-400">Atleta: {{ athlete.fullName }}</a>
            <span class="mx-1">/</span>
            <span class="text-gray-700 dark:text-gray-300">Pasos</span>
        </nav>

        {# Page header + period selector #}
        <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
                    Pasos de {{ athlete.fullName }}
                </h1>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{{ athlete.email }}</p>
            </div>
            <div class="flex gap-2">
                {% for option in [7, 30, 90] %}
                    <a href="{{ path('coach_athlete_steps', {athleteId: athlete.id, days: option}) }}"
                       class="px-3 py-1 rounded text-sm {{ days == option ? 'bg-indigo-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' }} transition">
                        {{ option }} días
                    </a>
                {% endfor %}
            </div>
        </div>

        {# Summary stat card #}
        <div class="mb-6 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm px-6 py-5">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Cumplimiento del objetivo</p>
                    <p class="mt-1 text-3xl font-bold {{ compliance >= 80 ? 'text-green-600 dark:text-green-400' : (compliance >= 50 ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400') }}">
                        {{ compliance }}%
                    </p>
                    <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">
                        Días con ≥ {{ stepsTarget|number_format(0, ',', '.') }} pasos / total días con datos
                    </p>
                </div>
                <div class="text-right">
                    <p class="text-sm text-gray-500 dark:text-gray-400">Objetivo diario</p>
                    <p class="mt-1 text-xl font-semibold text-gray-800 dark:text-gray-200">
                        {{ stepsTarget|number_format(0, ',', '.') }}
                    </p>
                    <p class="text-xs text-gray-400 dark:text-gray-500">pasos / día</p>
                </div>
            </div>
        </div>

        {# Steps table #}
        {% if steps is empty %}
            <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-6 py-12 text-center shadow-sm">
                <p class="text-sm text-gray-500 dark:text-gray-400">
                    Este atleta no tiene registros de pasos en los últimos {{ days }} días.
                </p>
            </div>
        {% else %}
            <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-900/50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Fecha</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Pasos</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Objetivo</th>
                            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Estado</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-800">
                        {% for entry in steps %}
                            {% set met = entry.steps >= stepsTarget %}
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-gray-900 dark:text-gray-100">
                                    {{ entry.date|date('d/m/Y') }}
                                </td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm font-medium {{ met ? 'text-green-700 dark:text-green-400' : 'text-red-700 dark:text-red-400' }}">
                                    {{ entry.steps|number_format(0, ',', '.') }}
                                </td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm text-gray-500 dark:text-gray-400">
                                    {{ stepsTarget|number_format(0, ',', '.') }}
                                </td>
                                <td class="whitespace-nowrap px-4 py-3 text-sm">
                                    {% if met %}
                                        <span class="inline-flex items-center gap-1 text-green-700 dark:text-green-400 font-semibold">✓</span>
                                    {% else %}
                                        <span class="inline-flex items-center gap-1 text-red-600 dark:text-red-400 font-semibold">✗</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}

    </main>
</div>
{% endblock %}
