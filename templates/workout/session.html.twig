{% extends 'base.html.twig' %}

{% block title %}{{ workoutLog.workoutSession.name }} — Entrenamiento{% endblock %}

{% block nav %}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900"
     data-controller="rest-timer">

    {# ── Header ── #}
    <header class="sticky top-0 z-10 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 shadow-sm">
        <div class="max-w-2xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
            <div class="min-w-0">
                <h1 class="text-base font-bold text-gray-900 dark:text-gray-100 truncate">
                    {{ workoutLog.workoutSession.name }}
                </h1>
                <p class="text-xs text-gray-500 dark:text-gray-400 truncate">
                    {{ workoutLog.assignedMesocycle.mesocycle.title }}
                </p>
            </div>
            {% if workoutLog.status.value == 'in_progress' %}
            <form method="POST"
                  action="{{ path('workout_complete', {workoutLogId: workoutLog.id}) }}"
                  onsubmit="return confirm('¿Confirmas que has completado el entrenamiento?');">
                <button type="submit"
                        class="shrink-0 rounded-md bg-green-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-500 active:bg-green-700">
                    Completar
                </button>
            </form>
            {% else %}
            <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-800">
                Completado
            </span>
            {% endif %}
        </div>
    </header>

    {# ── Flash messages ── #}
    <div class="max-w-2xl mx-auto px-4 pt-4">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-3 rounded-md {{ type == 'success' ? 'bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 text-green-800 dark:text-green-300' : 'bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-700 text-red-800 dark:text-red-300' }} px-4 py-3 text-sm">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {# ── Rest Timer ── #}
    <div class="max-w-2xl mx-auto px-4 pt-3">
        <div class="rounded-lg bg-indigo-50 dark:bg-indigo-950 border border-indigo-200 dark:border-indigo-900 px-4 py-3 hidden"
             data-rest-timer-target="timerPanel">
            <div class="flex items-center justify-between gap-4">
                <div>
                    <p class="text-xs font-medium text-indigo-700 dark:text-indigo-300 mb-1">Descanso</p>
                    <p class="text-3xl font-mono font-bold text-indigo-900 dark:text-indigo-200"
                       data-rest-timer-target="display">1:30</p>
                    <p class="text-xs text-indigo-500 dark:text-indigo-400 mt-1 hidden"
                       data-rest-timer-target="doneMessage">¡A por la siguiente serie!</p>
                </div>
                <div class="flex-1 max-w-xs">
                    <div class="h-2 bg-indigo-200 dark:bg-indigo-900 rounded-full overflow-hidden">
                        <div class="h-full bg-indigo-600 rounded-full transition-all duration-1000"
                             data-rest-timer-target="progressBar"
                             style="width: 100%;"></div>
                    </div>
                </div>
                <button type="button"
                        class="shrink-0 rounded-md border border-indigo-300 dark:border-indigo-700 bg-white dark:bg-gray-800 px-3 py-1.5 text-sm font-medium text-indigo-700 dark:text-indigo-300 hover:bg-indigo-50 dark:hover:bg-gray-700"
                        data-rest-timer-target="skipButton"
                        data-action="rest-timer#skip">
                    Saltar
                </button>
            </div>
        </div>
    </div>

    {# ── Exercise cards ── #}
    <main class="max-w-2xl mx-auto px-4 py-4 space-y-4"
          data-controller="workout"
          data-workout-state-value="{{ workoutState|json_encode }}"
          data-workout-log-url="{{ path('workout_set_log', {workoutLogId: workoutLog.id}) }}">

        {% for sessionExercise in sessionExercises %}
            {% include 'workout/_exercise_card.html.twig' with {
                sessionExercise: sessionExercise,
                setLogs: setLogsByExercise[sessionExercise.id] ?? [],
                workoutLog: workoutLog
            } %}
        {% endfor %}

        {% if sessionExercises is empty %}
            <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-6 py-10 text-center shadow-sm">
                <p class="text-sm text-gray-500 dark:text-gray-400">Esta sesión no tiene ejercicios.</p>
            </div>
        {% endif %}

    </main>

    {# ── Completion Modal ── #}
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 hidden"
         data-workout-target="completionModal">
        <div class="mx-4 w-full max-w-sm rounded-xl bg-white dark:bg-gray-800 p-6 text-center shadow-xl">
            <div class="text-4xl mb-3">🏆</div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">¡Series completadas!</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Has alcanzado el objetivo de series. Puedes completar el entrenamiento.</p>
            <form method="POST"
                  action="{{ path('workout_complete', {workoutLogId: workoutLog.id}) }}">
                <button type="submit"
                        class="w-full rounded-md bg-green-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-green-500">
                    Completar entrenamiento
                </button>
            </form>
            <button type="button"
                    class="mt-3 w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700"
                    data-action="workout#closeModal">
                Seguir entrenando
            </button>
        </div>
    </div>

</div>
{% endblock %}
