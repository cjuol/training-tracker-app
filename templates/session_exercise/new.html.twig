{% extends 'base.html.twig' %}

{% block title %}Añadir Ejercicio — Training Tracker{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 py-8">

        {# Breadcrumb #}
        <nav class="mb-6 flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
            <a href="{{ path('mesocycle_index') }}" class="hover:text-gray-700 dark:hover:text-gray-300">Mesociclos</a>
            <span>/</span>
            <a href="{{ path('mesocycle_show', {id: mesocycle.id}) }}" class="hover:text-gray-700 dark:hover:text-gray-300">{{ mesocycle.title }}</a>
            <span>/</span>
            <span class="text-gray-900 dark:text-gray-100 font-medium">{{ session.name }}</span>
            <span>/</span>
            <span class="text-gray-900 dark:text-gray-100 font-medium">Nuevo ejercicio</span>
        </nav>

        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 shadow-sm">
            <div class="px-6 py-5 border-b border-gray-200 dark:border-gray-700">
                <h1 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Añadir Ejercicio</h1>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Añade un ejercicio a la sesión <strong>{{ session.name }}</strong>.</p>
            </div>
            <div class="px-6 py-6">
                {{ form_start(form, {attr: {class: 'space-y-6'}}) }}

                    <div>
                        {{ form_label(form.exercise, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                        {{ form_widget(form.exercise) }}
                        {{ form_errors(form.exercise) }}
                    </div>

                    <div>
                        {{ form_label(form.seriesType, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                        {{ form_widget(form.seriesType) }}
                        {{ form_errors(form.seriesType) }}
                    </div>

                    <div class="grid grid-cols-3 gap-4">
                        <div>
                            {{ form_label(form.targetSets, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                            {{ form_widget(form.targetSets) }}
                            {{ form_errors(form.targetSets) }}
                        </div>
                        <div>
                            {{ form_label(form.targetReps, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                            {{ form_widget(form.targetReps) }}
                            {{ form_errors(form.targetReps) }}
                        </div>
                        <div>
                            {{ form_label(form.targetWeight, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                            {{ form_widget(form.targetWeight) }}
                            {{ form_errors(form.targetWeight) }}
                        </div>
                    </div>

                    <div>
                        {{ form_label(form.superseriesGroup, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 dark:text-gray-300'}}) }}
                        <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Asigna el mismo número a los ejercicios que forman una superserie o triserie.</p>
                        {{ form_widget(form.superseriesGroup) }}
                        {{ form_errors(form.superseriesGroup) }}
                    </div>

                    <div class="flex items-center gap-4 pt-2">
                        <button type="submit"
                                class="inline-flex justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                            Guardar
                        </button>
                        <a href="{{ path('mesocycle_show', {id: mesocycle.id}) }}"
                           class="text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100">
                            Cancelar
                        </a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>

    </div>
</div>
{% endblock %}
