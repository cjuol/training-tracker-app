{% extends 'base.html.twig' %}

{% block title %}
    {% if viewingAs == 'coach' %}
        Historial de {{ athlete.fullName }} — Training Tracker
    {% else %}
        Mi Historial — Training Tracker
    {% endif %}
{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        {# Breadcrumb #}
        {% if viewingAs == 'coach' %}
            <nav class="mb-4 text-sm text-gray-500 dark:text-gray-400">
                <a href="{{ path('app_dashboard') }}" class="hover:text-indigo-600 dark:hover:text-indigo-400">Dashboard</a>
                <span class="mx-1">/</span>
                <span class="text-gray-700 dark:text-gray-300">Historial de {{ athlete.fullName }}</span>
            </nav>
        {% endif %}

        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">
            {% if viewingAs == 'coach' %}
                Historial de {{ athlete.fullName }}
            {% else %}
                Mi Historial
            {% endif %}
        </h1>

        {% if logs is empty %}
            <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-6 py-12 text-center shadow-sm">
                <p class="text-sm text-gray-500 dark:text-gray-400">No hay registros de entrenamiento todavía.</p>
            </div>
        {% else %}
            <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-900/50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Fecha</th>
                            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Sesión</th>
                            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Mesociclo</th>
                            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Estado</th>
                            <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Duración</th>
                            <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700 bg-white dark:bg-gray-800">
                        {% for log in logs %}
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-900 dark:text-gray-100">
                                    {{ log.startTime|date('d/m/Y H:i') }}
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700 dark:text-gray-300">
                                    {{ log.workoutSession.name }}
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700 dark:text-gray-300">
                                    {{ log.assignedMesocycle.mesocycle.title }}
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm">
                                    {% if log.status.value == 'completed' %}
                                        <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
                                            Completado
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800">
                                            En progreso
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-600 dark:text-gray-400">
                                    {% if log.endTime %}
                                        {% set diffSeconds = log.endTime.timestamp - log.startTime.timestamp %}
                                        {% set minutes = (diffSeconds / 60)|round(0, 'floor') %}
                                        {% set secs = diffSeconds % 60 %}
                                        {{ minutes }}m {{ secs }}s
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-right text-sm">
                                    {% if viewingAs == 'coach' %}
                                        <a href="{{ path('coach_athlete_history_show', {athleteId: athlete.id, workoutLogId: log.id}) }}"
                                           class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 font-medium">Ver</a>
                                    {% else %}
                                        <a href="{{ path('history_show', {workoutLogId: log.id}) }}"
                                           class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 font-medium">Ver</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Pagination #}
            {% if totalPages > 1 %}
                <nav class="mt-6 flex items-center justify-between">
                    <div class="text-sm text-gray-500 dark:text-gray-400">
                        Página {{ page }} de {{ totalPages }} ({{ total }} registros)
                    </div>
                    <div class="flex gap-2">
                        {% if page > 1 %}
                            {% if viewingAs == 'coach' %}
                                <a href="{{ path('coach_athlete_history', {athleteId: athlete.id, page: page - 1}) }}"
                                   class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                                    Anterior
                                </a>
                            {% else %}
                                <a href="{{ path('history_index', {page: page - 1}) }}"
                                   class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                                    Anterior
                                </a>
                            {% endif %}
                        {% else %}
                            <span class="rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-3 py-1 text-sm text-gray-400 dark:text-gray-500 cursor-not-allowed">
                                Anterior
                            </span>
                        {% endif %}

                        {% if page < totalPages %}
                            {% if viewingAs == 'coach' %}
                                <a href="{{ path('coach_athlete_history', {athleteId: athlete.id, page: page + 1}) }}"
                                   class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                                    Siguiente
                                </a>
                            {% else %}
                                <a href="{{ path('history_index', {page: page + 1}) }}"
                                   class="rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-1 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                                    Siguiente
                                </a>
                            {% endif %}
                        {% else %}
                            <span class="rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-3 py-1 text-sm text-gray-400 dark:text-gray-500 cursor-not-allowed">
                                Siguiente
                            </span>
                        {% endif %}
                    </div>
                </nav>
            {% endif %}
        {% endif %}
    </main>
</div>
{% endblock %}
