{% extends 'base.html.twig' %}

{% block title %}
    {{ log.workoutSession.name }} — {{ log.startTime|date('d/m/Y') }} — Training Tracker
{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        {# Back link #}
        <div class="mb-4">
            <a href="{{ path(backRoute, backParams) }}"
               class="inline-flex items-center gap-1 text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 font-medium">
                &larr; Volver al historial
            </a>
        </div>

        {# Header card #}
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm p-6 mb-6">
            <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                    <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100">{{ log.workoutSession.name }}</h1>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                        Mesociclo: <span class="font-medium text-gray-700 dark:text-gray-300">{{ log.assignedMesocycle.mesocycle.title }}</span>
                    </p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        Fecha: <span class="font-medium text-gray-700 dark:text-gray-300">{{ log.startTime|date('d/m/Y H:i') }}</span>
                    </p>
                    {% if log.endTime %}
                        {% set diffSeconds = log.endTime.timestamp - log.startTime.timestamp %}
                        {% set minutes = (diffSeconds / 60)|round(0, 'floor') %}
                        {% set secs = diffSeconds % 60 %}
                        <p class="text-sm text-gray-500 dark:text-gray-400">
                            Duración: <span class="font-medium text-gray-700 dark:text-gray-300">{{ minutes }}m {{ secs }}s</span>
                        </p>
                    {% endif %}
                </div>
                <div>
                    {% if log.status.value == 'completed' %}
                        <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">
                            Completado
                        </span>
                    {% else %}
                        <span class="inline-flex items-center rounded-full bg-yellow-100 px-3 py-1 text-sm font-medium text-yellow-800">
                            En progreso
                        </span>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Sets grouped by SessionExercise #}
        {% set exerciseGroups = {} %}
        {% for setLog in log.setLogs %}
            {% set seId = setLog.sessionExercise.id %}
            {% if exerciseGroups[seId] is not defined %}
                {% set exerciseGroups = exerciseGroups|merge({(seId): {sessionExercise: setLog.sessionExercise, sets: []}}) %}
            {% endif %}
            {% set updatedGroup = exerciseGroups[seId]|merge({sets: exerciseGroups[seId].sets|merge([setLog])}) %}
            {% set exerciseGroups = exerciseGroups|merge({(seId): updatedGroup}) %}
        {% endfor %}

        {% if exerciseGroups is empty %}
            <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-6 py-10 text-center shadow-sm">
                <p class="text-sm text-gray-500 dark:text-gray-400">No se registraron series en esta sesión.</p>
            </div>
        {% else %}
            {% for seId, group in exerciseGroups %}
                {% set se = group.sessionExercise %}
                {% set measurementType = se.exercise.measurementType.value %}

                <div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-sm mb-4 overflow-hidden">
                    <div class="bg-gray-50 dark:bg-gray-900/50 border-b border-gray-200 dark:border-gray-700 px-6 py-3">
                        <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">{{ se.exercise.name }}</h2>
                        <p class="text-xs text-gray-400 dark:text-gray-500">{{ se.exercise.measurementType.label() }}</p>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-100 dark:divide-gray-700 text-sm">
                            <thead class="bg-white dark:bg-gray-800">
                                <tr>
                                    <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Serie</th>
                                    {% if measurementType == 'reps_weight' %}
                                        <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Reps</th>
                                        <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Peso (kg)</th>
                                        <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">RIR</th>
                                        <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Descanso (s)</th>
                                    {% elseif measurementType == 'time_distance' %}
                                        <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Duración (s)</th>
                                        <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Distancia (km)</th>
                                        <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Descanso (s)</th>
                                    {% elseif measurementType == 'time_kcal' %}
                                        <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Duración (s)</th>
                                        <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Kcal</th>
                                        <th class="px-4 py-2 text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Descanso (s)</th>
                                    {% endif %}
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                                {% for setLog in group.sets|sort((a, b) => a.setNumber <=> b.setNumber) %}
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                        <td class="px-4 py-2 font-medium text-gray-900 dark:text-gray-100">{{ setLog.setNumber }}</td>
                                        {% if measurementType == 'reps_weight' %}
                                            <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{ setLog.reps ?? '—' }}</td>
                                            <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{ setLog.weight ?? '—' }}</td>
                                            <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{ setLog.rir ?? '—' }}</td>
                                            <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{ setLog.restTimeSeconds ?? '—' }}</td>
                                        {% elseif measurementType == 'time_distance' %}
                                            <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{ setLog.timeDuration ?? '—' }}</td>
                                            <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{ setLog.distance ?? '—' }}</td>
                                            <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{ setLog.restTimeSeconds ?? '—' }}</td>
                                        {% elseif measurementType == 'time_kcal' %}
                                            <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{ setLog.timeDuration ?? '—' }}</td>
                                            <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{ setLog.kcal ?? '—' }}</td>
                                            <td class="px-4 py-2 text-gray-700 dark:text-gray-300">{{ setLog.restTimeSeconds ?? '—' }}</td>
                                        {% endif %}
                                    </tr>
                                    {% if setLog.observacion %}
                                        <tr>
                                            <td colspan="5" class="px-4 py-1 text-xs text-gray-400 dark:text-gray-500 italic bg-gray-50 dark:bg-gray-900/30">
                                                Observación: {{ setLog.observacion }}
                                            </td>
                                        </tr>
                                    {% endif %}
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endfor %}
        {% endif %}

    </main>
</div>
{% endblock %}
